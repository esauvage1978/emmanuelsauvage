---
/** Schémas SVG légers (thème visuel par article), sans dépendance image externe. */
type Variant =
	| 'refonte'
	| 'api'
	| 'validation'
	| 'sheets'
	| 'webhook'
	| 'problem'
	| 'openapi'
	| 'modules'
	| 'ops'
	| 'privacy'
	| 'vitrine';

type Props = {
	variant: Variant;
	class?: string;
};

const { variant, class: className = '' } = Astro.props;
---

<figure class:list={['blogIllu', className]}>
	{
		variant === 'refonte' && (
			<svg viewBox="0 0 640 280" width="640" height="280" role="img" aria-labelledby="illu-refonte-title">
				<title id="illu-refonte-title">Schéma : évolutions ciblées versus refonte large</title>
				<defs>
					<linearGradient id="g1" x1="0" y1="0" x2="1" y2="1">
						<stop offset="0" stop-color="#4f6ef7" stop-opacity="0.35" />
						<stop offset="1" stop-color="#c45c2e" stop-opacity="0.25" />
					</linearGradient>
				</defs>
				<rect width="640" height="280" rx="20" fill="#f7f8fc" stroke="rgba(45,45,45,0.12)" />
				<rect x="40" y="60" width="240" height="160" rx="14" fill="url(#g1)" stroke="#2f3a8f" stroke-opacity="0.35" />
				<text x="160" y="115" text-anchor="middle" fill="#2f3a8f" font-size="18" font-weight="700" font-family="system-ui,sans-serif">
					Itérations
				</text>
				<text x="160" y="145" text-anchor="middle" fill="#5b5b5b" font-size="13" font-family="system-ui,sans-serif">
					risque maîtrisé
				</text>
				<text x="160" y="175" text-anchor="middle" fill="#5b5b5b" font-size="13" font-family="system-ui,sans-serif">
					livrable court
				</text>
				<rect x="360" y="60" width="240" height="160" rx="14" fill="rgba(47,58,143,0.08)" stroke="#c45c2e" stroke-opacity="0.5" />
				<text x="480" y="115" text-anchor="middle" fill="#2f3a8f" font-size="18" font-weight="700" font-family="system-ui,sans-serif">
					Refonte
				</text>
				<text x="480" y="145" text-anchor="middle" fill="#5b5b5b" font-size="13" font-family="system-ui,sans-serif">
					coût global
				</text>
				<text x="480" y="175" text-anchor="middle" fill="#5b5b5b" font-size="13" font-family="system-ui,sans-serif">
					transfert / QA
				</text>
				<text x="320" y="38" text-anchor="middle" fill="#2d2d2d" font-size="15" font-weight="700" font-family="system-ui,sans-serif">
					Décision produit &amp; technique
				</text>
			</svg>
		)
	}
	{
		variant === 'api' && (
			<svg viewBox="0 0 640 220" width="640" height="220" role="img" aria-labelledby="illu-api-title">
				<title id="illu-api-title">Schéma : clients et versions d’API</title>
				<rect width="640" height="220" rx="20" fill="#f7f8fc" stroke="rgba(45,45,45,0.12)" />
				<rect x="48" y="72" width="120" height="76" rx="12" fill="#fff" stroke="#4f6ef7" stroke-width="2" />
				<text x="108" y="118" text-anchor="middle" fill="#2f3a8f" font-size="14" font-weight="700" font-family="system-ui,sans-serif">
					SPA
				</text>
				<rect x="208" y="72" width="120" height="76" rx="12" fill="#fff" stroke="#c45c2e" stroke-width="2" />
				<text x="268" y="118" text-anchor="middle" fill="#2f3a8f" font-size="14" font-weight="700" font-family="system-ui,sans-serif">
					Mobile
				</text>
				<rect x="368" y="72" width="120" height="76" rx="12" fill="#fff" stroke="#2f3a8f" stroke-width="2" />
				<text x="428" y="118" text-anchor="middle" fill="#2f3a8f" font-size="14" font-weight="700" font-family="system-ui,sans-serif">
					Partenaire
				</text>
				<rect x="240" y="168" width="160" height="36" rx="10" fill="rgba(79,110,247,0.15)" stroke="#2f3a8f" />
				<text x="320" y="192" text-anchor="middle" fill="#2f3a8f" font-size="13" font-weight="700" font-family="system-ui,sans-serif">
					API /api/v1 … v2
				</text>
				<text x="320" y="48" text-anchor="middle" fill="#2d2d2d" font-size="15" font-weight="700" font-family="system-ui,sans-serif">
					Compatibilité &amp; déploiement
				</text>
			</svg>
		)
	}
	{
		variant === 'validation' && (
			<svg viewBox="0 0 640 200" width="640" height="200" role="img" aria-labelledby="illu-val-title">
				<title id="illu-val-title">Schéma : requête filtrée par validation</title>
				<rect width="640" height="200" rx="20" fill="#f7f8fc" stroke="rgba(45,45,45,0.12)" />
				<text x="320" y="36" text-anchor="middle" fill="#2d2d2d" font-size="15" font-weight="700" font-family="system-ui,sans-serif">
					Requête → contraintes → réponse ou erreurs structurées
				</text>
				<path d="M80 100 H520" stroke="rgba(47,58,143,0.35)" stroke-width="3" stroke-dasharray="8 6" />
				<circle cx="120" cy="100" r="28" fill="#fff" stroke="#4f6ef7" stroke-width="2" />
				<text x="120" y="106" text-anchor="middle" fill="#2f3a8f" font-size="13" font-weight="700" font-family="system-ui,sans-serif">
					JSON
				</text>
				<rect x="240" y="72" width="160" height="56" rx="12" fill="rgba(196,92,46,0.12)" stroke="#c45c2e" />
				<text x="320" y="106" text-anchor="middle" fill="#a64d27" font-size="14" font-weight="700" font-family="system-ui,sans-serif">
					Validator
				</text>
				<circle cx="520" cy="100" r="28" fill="#fff" stroke="#2f3a8f" stroke-width="2" />
				<text x="520" y="106" text-anchor="middle" fill="#2f3a8f" font-size="13" font-weight="700" font-family="system-ui,sans-serif">
					422
				</text>
			</svg>
		)
	}
	{
		variant === 'sheets' && (
			<svg viewBox="0 0 640 240" width="640" height="240" role="img" aria-labelledby="illu-sh-title">
				<title id="illu-sh-title">Schéma : feuille partagée versus base applicative</title>
				<rect width="640" height="240" rx="20" fill="#f7f8fc" stroke="rgba(45,45,45,0.12)" />
				<text x="320" y="36" text-anchor="middle" fill="#2d2d2d" font-size="15" font-weight="700" font-family="system-ui,sans-serif">
					Croissance des usages
				</text>
				<g transform="translate(60,70)">
					<rect width="220" height="130" rx="10" fill="#fff" stroke="#4f6ef7" />
					<line x1="0" y1="36" x2="220" y2="36" stroke="rgba(45,45,45,0.1)" />
					<line x1="0" y1="72" x2="220" y2="72" stroke="rgba(45,45,45,0.1)" />
					<line x1="0" y1="108" x2="220" y2="108" stroke="rgba(45,45,45,0.1)" />
					<line x1="55" y1="0" x2="55" y2="130" stroke="rgba(45,45,45,0.1)" />
					<text x="110" y="24" text-anchor="middle" fill="#2f3a8f" font-size="12" font-weight="700" font-family="system-ui,sans-serif">
						Sheets
					</text>
				</g>
				<path d="M310 135 L350 135" stroke="#c45c2e" stroke-width="3" marker-end="url(#blogIlluArrSheets)" />
				<defs>
					<marker id="blogIlluArrSheets" markerWidth="8" markerHeight="8" refX="6" refY="4" orient="auto">
						<polygon points="0 0, 8 4, 0 8" fill="#c45c2e" />
					</marker>
				</defs>
				<g transform="translate(360,70)">
					<rect width="220" height="130" rx="10" fill="rgba(47,58,143,0.06)" stroke="#2f3a8f" />
					<text x="110" y="70" text-anchor="middle" fill="#2f3a8f" font-size="13" font-weight="700" font-family="system-ui,sans-serif">
						App + rôles + audit
					</text>
				</g>
			</svg>
		)
	}
	{
		variant === 'webhook' && (
			<svg viewBox="0 0 640 220" width="640" height="220" role="img" aria-labelledby="illu-wh-title">
				<title id="illu-wh-title">Schéma : livraisons webhook avec retries</title>
				<rect width="640" height="220" rx="20" fill="#f7f8fc" stroke="rgba(45,45,45,0.12)" />
				<text x="320" y="36" text-anchor="middle" fill="#2d2d2d" font-size="15" font-weight="700" font-family="system-ui,sans-serif">
					Retries &amp; idempotence
				</text>
				<rect x="60" y="80" width="140" height="64" rx="12" fill="#fff" stroke="#2f3a8f" stroke-width="2" />
				<text x="130" y="120" text-anchor="middle" fill="#2f3a8f" font-size="13" font-weight="700" font-family="system-ui,sans-serif">
					Émetteur
				</text>
				<path d="M210 112 H430" stroke="#4f6ef7" stroke-width="2" />
				<text x="320" y="102" text-anchor="middle" fill="#c45c2e" font-size="11" font-weight="700" font-family="system-ui,sans-serif">
					POST + Idempotency-Key
				</text>
				<rect x="440" y="80" width="140" height="64" rx="12" fill="rgba(196,92,46,0.1)" stroke="#c45c2e" />
				<text x="510" y="120" text-anchor="middle" fill="#a64d27" font-size="13" font-weight="700" font-family="system-ui,sans-serif">
					Récepteur
				</text>
				<text x="320" y="188" text-anchor="middle" fill="#5b5b5b" font-size="12" font-family="system-ui,sans-serif">
					200 rapide + traitement asynchrone recommandé
				</text>
			</svg>
		)
	}
	{
		variant === 'problem' && (
			<svg viewBox="0 0 640 200" width="640" height="200" role="img" aria-labelledby="illu-prob-title">
				<title id="illu-prob-title">Schéma : réponse d’erreur structurée Problem+JSON</title>
				<rect width="640" height="200" rx="20" fill="#f7f8fc" stroke="rgba(45,45,45,0.12)" />
				<text x="320" y="38" text-anchor="middle" fill="#2d2d2d" font-size="15" font-weight="700" font-family="system-ui,sans-serif">
					application/problem+json
				</text>
				<rect x="120" y="70" width="400" height="100" rx="12" fill="#1a1b26" stroke="rgba(255,255,255,0.08)" />
				<text x="140" y="100" fill="#fca5a5" font-size="13" font-family="ui-monospace,monospace">
					&quot;type&quot;: &quot;https://…/errors/invalid&quot;,
				</text>
				<text x="140" y="122" fill="#e4e4e7" font-size="13" font-family="ui-monospace,monospace">
					&quot;title&quot;: &quot;Validation Failed&quot;,
				</text>
				<text x="140" y="144" fill="#a5b4fc" font-size="13" font-family="ui-monospace,monospace">
					&quot;status&quot;: 422
				</text>
			</svg>
		)
	}
	{
		variant === 'openapi' && (
			<svg viewBox="0 0 640 200" width="640" height="200" role="img" aria-labelledby="illu-oapi-title">
				<title id="illu-oapi-title">Schéma : contrat OpenAPI partagé entre équipes</title>
				<rect width="640" height="200" rx="20" fill="#f7f8fc" stroke="rgba(45,45,45,0.12)" />
				<text x="320" y="36" text-anchor="middle" fill="#2d2d2d" font-size="15" font-weight="700" font-family="system-ui,sans-serif">
					Contrat → clients → tests
				</text>
				<rect x="50" y="70" width="150" height="90" rx="12" fill="#fff" stroke="#2f3a8f" stroke-width="2" />
				<text x="125" y="118" text-anchor="middle" fill="#2f3a8f" font-size="13" font-weight="700" font-family="system-ui,sans-serif">
					openapi.yaml
				</text>
				<text x="245" y="125" fill="#c45c2e" font-size="20" font-weight="700" font-family="system-ui,sans-serif">
					→
				</text>
				<rect x="280" y="70" width="130" height="90" rx="12" fill="rgba(79,110,247,0.1)" stroke="#4f6ef7" />
				<text x="345" y="118" text-anchor="middle" fill="#2f3a8f" font-size="12" font-weight="700" font-family="system-ui,sans-serif">
					SDK / mocks
				</text>
				<text x="435" y="125" fill="#c45c2e" font-size="20" font-weight="700" font-family="system-ui,sans-serif">
					→
				</text>
				<rect x="470" y="70" width="120" height="90" rx="12" fill="rgba(196,92,46,0.1)" stroke="#c45c2e" />
				<text x="530" y="118" text-anchor="middle" fill="#a64d27" font-size="12" font-weight="700" font-family="system-ui,sans-serif">
					Tests contrat
				</text>
			</svg>
		)
	}
	{
		variant === 'modules' && (
			<svg viewBox="0 0 640 220" width="640" height="220" role="img" aria-labelledby="illu-mod-title">
				<title id="illu-mod-title">Schéma : monolithe avec frontières de modules</title>
				<rect width="640" height="220" rx="20" fill="#f7f8fc" stroke="rgba(45,45,45,0.12)" />
				<text x="320" y="36" text-anchor="middle" fill="#2d2d2d" font-size="15" font-weight="700" font-family="system-ui,sans-serif">
					Une appli, plusieurs contextes délimités
				</text>
				<rect x="80" y="70" width="140" height="110" rx="12" fill="#fff" stroke="#2f3a8f" />
				<text x="150" y="130" text-anchor="middle" fill="#2f3a8f" font-size="13" font-weight="700" font-family="system-ui,sans-serif">
					Facturation
				</text>
				<rect x="250" y="70" width="140" height="110" rx="12" fill="#fff" stroke="#4f6ef7" />
				<text x="320" y="130" text-anchor="middle" fill="#2f3a8f" font-size="13" font-weight="700" font-family="system-ui,sans-serif">
					Stock
				</text>
				<rect x="420" y="70" width="140" height="110" rx="12" fill="#fff" stroke="#c45c2e" />
				<text x="490" y="130" text-anchor="middle" fill="#a64d27" font-size="13" font-weight="700" font-family="system-ui,sans-serif">
					CRM sync
				</text>
				<text x="320" y="198" text-anchor="middle" fill="#5b5b5b" font-size="12" font-family="system-ui,sans-serif">
					Dépendances explicites, pas d’appels transverses « sauvages »
				</text>
			</svg>
		)
	}
	{
		variant === 'ops' && (
			<svg viewBox="0 0 640 200" width="640" height="200" role="img" aria-labelledby="illu-ops-title">
				<title id="illu-ops-title">Schéma : indicateurs de maintenance applicative</title>
				<rect width="640" height="200" rx="20" fill="#f7f8fc" stroke="rgba(45,45,45,0.12)" />
				<text x="320" y="36" text-anchor="middle" fill="#2d2d2d" font-size="15" font-weight="700" font-family="system-ui,sans-serif">
					Suivi continu
				</text>
				<rect x="60" y="65" width="150" height="72" rx="10" fill="rgba(47,58,143,0.08)" stroke="#2f3a8f" />
				<text x="135" y="108" text-anchor="middle" fill="#2f3a8f" font-size="12" font-weight="700" font-family="system-ui,sans-serif">
					composer audit
				</text>
				<rect x="245" y="65" width="150" height="72" rx="10" fill="rgba(79,110,247,0.1)" stroke="#4f6ef7" />
				<text x="320" y="108" text-anchor="middle" fill="#2f3a8f" font-size="12" font-weight="700" font-family="system-ui,sans-serif">
					migrations
				</text>
				<rect x="430" y="65" width="150" height="72" rx="10" fill="rgba(196,92,46,0.1)" stroke="#c45c2e" />
				<text x="505" y="108" text-anchor="middle" fill="#a64d27" font-size="12" font-weight="700" font-family="system-ui,sans-serif">
					perfs / logs
				</text>
			</svg>
		)
	}
	{
		variant === 'privacy' && (
			<svg viewBox="0 0 640 200" width="640" height="200" role="img" aria-labelledby="illu-priv-title">
				<title id="illu-priv-title">Schéma : minimisation des données exposées par l’API</title>
				<rect width="640" height="200" rx="20" fill="#f7f8fc" stroke="rgba(45,45,45,0.12)" />
				<text x="320" y="36" text-anchor="middle" fill="#2d2d2d" font-size="15" font-weight="700" font-family="system-ui,sans-serif">
					Moins de champs, moins de risque
				</text>
				<rect x="100" y="70" width="180" height="90" rx="12" fill="#fff" stroke="#2f3a8f" stroke-width="2" />
				<text x="190" y="125" text-anchor="middle" fill="#2f3a8f" font-size="13" font-weight="700" font-family="system-ui,sans-serif">
					Modèle interne
				</text>
				<text x="310" y="125" fill="#c45c2e" font-size="22" font-weight="700" font-family="system-ui,sans-serif">
					⇒
				</text>
				<rect x="360" y="70" width="180" height="90" rx="12" fill="rgba(196,92,46,0.08)" stroke="#c45c2e" />
				<text x="450" y="125" text-anchor="middle" fill="#a64d27" font-size="13" font-weight="700" font-family="system-ui,sans-serif">
					DTO public / audit
				</text>
			</svg>
		)
	}
	{
		variant === 'vitrine' && (
			<svg viewBox="0 0 640 240" width="640" height="240" role="img" aria-labelledby="illu-vit-title">
				<title id="illu-vit-title">Schéma : site statique Astro, proxy contact, Zapier et Mailjet</title>
				<rect width="640" height="240" rx="20" fill="#f7f8fc" stroke="rgba(45,45,45,0.12)" />
				<text x="320" y="34" text-anchor="middle" fill="#2d2d2d" font-size="15" font-weight="700" font-family="system-ui,sans-serif">
					Astro (SSG) → proxy → Zapier → Mailjet
				</text>
				<rect x="40" y="58" width="120" height="72" rx="10" fill="#fff" stroke="#2f3a8f" stroke-width="2" />
				<text x="100" y="100" text-anchor="middle" fill="#2f3a8f" font-size="12" font-weight="700" font-family="system-ui,sans-serif">
					Astro
				</text>
				<text x="100" y="118" text-anchor="middle" fill="#5b5b5b" font-size="10" font-family="system-ui,sans-serif">
					HTML statique
				</text>
				<text x="175" y="100" fill="#c45c2e" font-size="18" font-weight="700">→</text>
				<rect x="200" y="58" width="110" height="72" rx="10" fill="rgba(79,110,247,0.12)" stroke="#4f6ef7" />
				<text x="255" y="100" text-anchor="middle" fill="#2f3a8f" font-size="11" font-weight="700" font-family="system-ui,sans-serif">
					PHP / proxy
				</text>
				<text x="335" y="100" fill="#c45c2e" font-size="18" font-weight="700">→</text>
				<rect x="360" y="58" width="100" height="72" rx="10" fill="rgba(196,92,46,0.12)" stroke="#c45c2e" />
				<text x="410" y="100" text-anchor="middle" fill="#a64d27" font-size="11" font-weight="700" font-family="system-ui,sans-serif">
					Zapier
				</text>
				<text x="485" y="100" fill="#c45c2e" font-size="18" font-weight="700">→</text>
				<rect x="500" y="58" width="100" height="72" rx="10" fill="#fff" stroke="#2f3a8f" />
				<text x="550" y="100" text-anchor="middle" fill="#2f3a8f" font-size="11" font-weight="700" font-family="system-ui,sans-serif">
					Mailjet
				</text>
				<text x="320" y="168" text-anchor="middle" fill="#5b5b5b" font-size="12" font-family="system-ui,sans-serif">
					Formulaire JSON same-origin · template transactionnel · pas de backend Node en prod
				</text>
			</svg>
		)
	}
</figure>

<style>
	.blogIllu {
		margin: 0;
		border-radius: var(--radius, 16px);
		overflow: hidden;
		border: 1px solid var(--color-border, rgba(45, 45, 45, 0.12));
		background: rgba(255, 255, 255, 0.9);
		box-shadow: var(--shadow-sm, 0 1px 2px rgba(16, 24, 40, 0.06));
	}

	.blogIllu svg {
		display: block;
		width: 100%;
		height: auto;
		vertical-align: middle;
	}
</style>

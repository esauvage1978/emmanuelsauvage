---
/**
 * Bandeau cookies (RGPD) :
 * - Aucun cookie non-essentiel n’est déposé tant que l’utilisateur n’a pas consenti.
 * - Le consentement est stocké en localStorage (et peut être retiré).
 *
 * Intégration : placer <CookieBanner /> en bas du body (dans une page ou un layout).
 */
---

<div class="cookie" data-cookie-root hidden>
	<div class="cookie__card" role="dialog" aria-modal="true" aria-label="Gestion des cookies">
		<div class="cookie__content">
			<h2>Cookies &amp; confidentialité</h2>
			<p>
				Nous utilisons des cookies strictement nécessaires au bon fonctionnement du site. Avec votre accord, nous
				pourrions également utiliser des cookies de mesure d’audience pour améliorer l’expérience.
				Vous pouvez accepter, refuser, ou personnaliser vos choix.
			</p>
			<p class="cookie__links">
				<a href="/cookies">En savoir plus</a>
				<span aria-hidden="true">·</span>
				<a href="/politique-de-confidentialite">Politique de confidentialité</a>
			</p>
		</div>

		<div class="cookie__actions">
			<button type="button" class="btn btn--ghost" data-cookie-settings>Personnaliser</button>
			<button type="button" class="btn btn--ghost" data-cookie-reject>Refuser</button>
			<button type="button" class="btn btn--primary" data-cookie-accept>Accepter</button>
		</div>
	</div>
</div>

<div class="prefs" data-cookie-prefs hidden>
	<div class="prefs__card" role="dialog" aria-modal="true" aria-label="Préférences cookies">
		<div class="prefs__head">
			<h2>Préférences cookies</h2>
			<button type="button" class="iconBtn" aria-label="Fermer" data-cookie-close>✕</button>
		</div>

		<div class="prefs__body">
			<div class="pref">
				<div>
					<h3>Cookies nécessaires</h3>
					<p>Indispensables au fonctionnement du site. Toujours actifs.</p>
				</div>
				<div class="toggle toggle--locked" aria-hidden="true">Activés</div>
			</div>

			<div class="pref">
				<div>
					<h3>Mesure d’audience</h3>
					<p>Permet de mesurer la fréquentation et d’améliorer le site.</p>
				</div>
				<label class="switch">
					<input type="checkbox" data-cookie-analytics />
					<span class="switch__ui" aria-hidden="true"></span>
					<span class="srOnly">Activer la mesure d’audience</span>
				</label>
			</div>
		</div>

		<div class="prefs__actions">
			<button type="button" class="btn btn--ghost" data-cookie-save>Enregistrer</button>
			<button type="button" class="btn btn--primary" data-cookie-accept>Accepter tout</button>
		</div>
	</div>
</div>

<script is:inline>
	(() => {
		const KEY = 'es_cookie_consent_v1';
		const root = document.querySelector('[data-cookie-root]');
		const prefs = document.querySelector('[data-cookie-prefs]');
		if (!root || !prefs) return;

		const acceptBtns = document.querySelectorAll('[data-cookie-accept]');
		const rejectBtn = document.querySelector('[data-cookie-reject]');
		const settingsBtn = document.querySelector('[data-cookie-settings]');
		const closeBtn = document.querySelector('[data-cookie-close]');
		const saveBtn = document.querySelector('[data-cookie-save]');
		const analyticsInput = document.querySelector('[data-cookie-analytics]');

		const read = () => {
			try {
				const raw = localStorage.getItem(KEY);
				return raw ? JSON.parse(raw) : null;
			} catch {
				return null;
			}
		};

		const write = (value) => {
			localStorage.setItem(KEY, JSON.stringify({ ...value, updatedAt: new Date().toISOString() }));
			window.dispatchEvent(new CustomEvent('cookie-consent:change', { detail: value }));
		};

		const showBanner = () => {
			root.hidden = false;
			document.documentElement.style.scrollBehavior = 'auto';
		};

		const hideBanner = () => {
			root.hidden = true;
		};

		const openPrefs = () => {
			prefs.hidden = false;
			const current = read();
			if (analyticsInput) analyticsInput.checked = Boolean(current?.analytics);
		};

		const closePrefs = () => {
			prefs.hidden = true;
		};

		const acceptAll = () => {
			write({ necessary: true, analytics: true });
			hideBanner();
			closePrefs();
		};

		const rejectAll = () => {
			write({ necessary: true, analytics: false });
			hideBanner();
			closePrefs();
		};

		const savePrefs = () => {
			write({ necessary: true, analytics: Boolean(analyticsInput && analyticsInput.checked) });
			hideBanner();
			closePrefs();
		};

		acceptBtns.forEach((btn) => btn.addEventListener('click', acceptAll));
		rejectBtn && rejectBtn.addEventListener('click', rejectAll);
		settingsBtn && settingsBtn.addEventListener('click', openPrefs);
		closeBtn && closeBtn.addEventListener('click', closePrefs);
		saveBtn && saveBtn.addEventListener('click', savePrefs);

		const existing = read();
		if (!existing) showBanner();
	})();
</script>

<style>
	.cookie[hidden],
	.prefs[hidden] {
		display: none !important;
	}

	.cookie,
	.prefs {
		position: fixed;
		inset: 0;
		display: grid;
		place-items: end center;
		padding: 18px;
		background: rgba(45, 45, 45, 0.45);
		backdrop-filter: blur(6px);
		z-index: 1000;
	}

	.prefs {
		place-items: center;
	}

	.cookie__card,
	.prefs__card {
		width: min(980px, 100%);
		background: white;
		border: 1px solid var(--color-border);
		border-radius: 18px;
		box-shadow: var(--shadow-md);
		padding: 16px;
	}

	.cookie__card {
		display: grid;
		grid-template-columns: 1.2fr 0.8fr;
		gap: 14px;
		align-items: center;
	}

	h2 {
		margin: 0 0 8px;
		font-size: 18px;
		letter-spacing: -0.02em;
	}

	p {
		margin: 0 0 10px;
		color: var(--color-muted);
	}

	.cookie__links {
		display: flex;
		gap: 10px;
		align-items: center;
		margin: 0;
		font-size: 14px;
	}

	.cookie__links a {
		color: var(--color-primary);
		text-decoration: underline;
		text-decoration-color: rgba(79, 110, 247, 0.35);
	}

	.cookie__actions,
	.prefs__actions {
		display: flex;
		gap: 10px;
		justify-content: flex-end;
		flex-wrap: wrap;
	}

	.btn {
		font: inherit;
		border-radius: 12px;
		padding: 10px 12px;
		border: 1px solid var(--color-border);
		background: white;
		cursor: pointer;
		font-weight: 700;
	}

	.btn--primary {
		border-color: transparent;
		background: var(--color-primary);
		color: white;
	}

	.btn--ghost {
		background: rgba(247, 248, 252, 0.9);
	}

	.prefs__head {
		display: flex;
		justify-content: space-between;
		align-items: center;
		gap: 10px;
		margin-bottom: 10px;
	}

	.iconBtn {
		font: inherit;
		border: 1px solid var(--color-border);
		background: white;
		border-radius: 12px;
		width: 40px;
		height: 40px;
		cursor: pointer;
	}

	.prefs__body {
		display: grid;
		gap: 12px;
	}

	.pref {
		display: grid;
		grid-template-columns: 1fr auto;
		gap: 14px;
		align-items: center;
		padding: 14px;
		border: 1px solid var(--color-border);
		border-radius: 16px;
		background: rgba(247, 248, 252, 0.8);
	}

	h3 {
		margin: 0 0 6px;
		font-size: 16px;
		letter-spacing: -0.01em;
	}

	.toggle--locked {
		color: var(--color-muted);
		font-weight: 700;
	}

	.switch {
		position: relative;
		display: inline-flex;
		align-items: center;
	}

	.switch input {
		position: absolute;
		opacity: 0;
		pointer-events: none;
	}

	.switch__ui {
		width: 52px;
		height: 30px;
		border-radius: 999px;
		background: rgba(45, 45, 45, 0.18);
		border: 1px solid var(--color-border);
		position: relative;
		transition: background 0.15s ease;
	}

	.switch__ui::after {
		content: '';
		width: 24px;
		height: 24px;
		border-radius: 999px;
		background: white;
		position: absolute;
		top: 2px;
		left: 2px;
		box-shadow: var(--shadow-sm);
		transition: transform 0.15s ease;
	}

	.switch input:checked + .switch__ui {
		background: var(--color-spot-soft);
		border-color: color-mix(in srgb, var(--color-spot) 45%, transparent);
	}

	.switch input:checked + .switch__ui::after {
		transform: translateX(22px);
	}

	.srOnly {
		position: absolute;
		width: 1px;
		height: 1px;
		padding: 0;
		margin: -1px;
		overflow: hidden;
		clip: rect(0, 0, 0, 0);
		white-space: nowrap;
		border: 0;
	}

	@media (max-width: 820px) {
		.cookie__card {
			grid-template-columns: 1fr;
		}

		.cookie__actions,
		.prefs__actions {
			justify-content: flex-start;
		}
	}
</style>

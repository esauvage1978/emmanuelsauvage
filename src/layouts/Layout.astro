---
type Props = {
	title?: string;
	description?: string;
	/** Ressource LCP probable (ex. hero) — améliore FCP/LCP sur la home */
	preloadLcpHref?: string;
	preloadLcpType?: string;
};

import CookieBanner from '../components/CookieBanner.astro';
import '@fontsource-variable/inter/wght.css';

const {
	title = 'Emmanuel Sauvage — Consultant en optimisation d’outils digitaux',
	description = 'Audit, optimisation des processus, développement d’outils métier et automatisation des workflows pour améliorer l’efficacité opérationnelle des entreprises.',
	preloadLcpHref,
	preloadLcpType = 'image/svg+xml',
} = Astro.props;
---

<!doctype html>
<html lang="fr">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<link rel="icon" type="image/png" sizes="32x32" href="/images/favicon-32x32.png" />
		<link rel="icon" type="image/png" sizes="16x16" href="/images/favicon-16x16.png" />
		<link rel="apple-touch-icon" sizes="180x180" href="/images/apple-touch-icon.png" />
		<link rel="shortcut icon" href="/favicon.png" />
		<meta name="generator" content={Astro.generator} />
		{
			preloadLcpHref ? (
				<link rel="preload" href={preloadLcpHref} as="image" type={preloadLcpType} />
			) : null
		}
		<title>{title}</title>
		<meta name="description" content={description} />

		<!--
			Mesure d’audience : GTM + gtag.js — chargés uniquement après consentement « mesure d’audience » (RGPD).
			Si la même propriété GA4 (G-JV833GXDJL) est aussi déclenchée dans GTM, désactivez l’une des deux pour éviter le double comptage.
		-->
		<script is:inline>
			(function () {
				var gtmId = 'GTM-56RLPDSX';
				var gaMeasurementId = 'G-JV833GXDJL';

				window.dataLayer = window.dataLayer || [];

				var gtmLoaded = false;
				function loadGtm() {
					if (gtmLoaded) return;
					gtmLoaded = true;
					window.dataLayer.push({ 'gtm.start': new Date().getTime(), event: 'gtm.js' });
					var s = document.createElement('script');
					s.async = true;
					s.src = 'https://www.googletagmanager.com/gtm.js?id=' + gtmId;
					document.head.appendChild(s);
				}

				var gtagLoaded = false;
				function loadGtag() {
					if (gtagLoaded) return;
					gtagLoaded = true;
					function gtag() {
						dataLayer.push(arguments);
					}
					window.gtag = gtag;
					gtag('js', new Date());
					gtag('config', gaMeasurementId);
					var g = document.createElement('script');
					g.async = true;
					g.src = 'https://www.googletagmanager.com/gtag/js?id=' + encodeURIComponent(gaMeasurementId);
					document.head.appendChild(g);
				}

				function loadAnalytics() {
					loadGtm();
					loadGtag();
				}

				function hasAnalyticsConsent() {
					try {
						var raw = localStorage.getItem('es_cookie_consent_v1');
						var o = raw ? JSON.parse(raw) : null;
						return Boolean(o && o.analytics === true);
					} catch (e) {
						return false;
					}
				}

				if (hasAnalyticsConsent()) loadAnalytics();
				window.addEventListener('cookie-consent:change', function (ev) {
					if (ev.detail && ev.detail.analytics === true) loadAnalytics();
				});
			})();
		</script>
		<!-- End Google Tag Manager + gtag.js -->
	</head>
	<body>
		<!-- Google Tag Manager (noscript) -->
		<noscript>
			<iframe
				src="https://www.googletagmanager.com/ns.html?id=GTM-56RLPDSX"
				height="0"
				width="0"
				style="display:none;visibility:hidden"
				title="Google Tag Manager"></iframe>
		</noscript>
		<!-- End Google Tag Manager (noscript) -->

		<slot />
		<CookieBanner />
	</body>
</html>

<style>
	:root {
		--color-primary: #2f3a8f;
		--color-accent: #4f6ef7;
		--color-text: #2d2d2d;
		--color-muted: #5b5b5b;
		--color-border: rgba(45, 45, 45, 0.12);
		--color-surface: #ffffff;
		--color-bg: #f7f8fc;
		--shadow-sm: 0 1px 2px rgba(16, 24, 40, 0.06);
		--shadow-md: 0 10px 30px rgba(16, 24, 40, 0.10);
		--radius: 16px;
	}

	html,
	body {
		margin: 0;
		width: 100%;
		min-height: 100%;
	}

	body {
		background: var(--color-bg);
		color: var(--color-text);
		font-family: 'Inter Variable', Inter, ui-sans-serif, system-ui, -apple-system, 'Segoe UI', Roboto, Arial, sans-serif;
		line-height: 1.5;
		letter-spacing: -0.01em;
	}

	a {
		color: inherit;
	}

	:focus-visible {
		outline: 3px solid rgba(79, 110, 247, 0.55);
		outline-offset: 2px;
	}

	::selection {
		background: rgba(47, 58, 143, 0.18);
	}
</style>

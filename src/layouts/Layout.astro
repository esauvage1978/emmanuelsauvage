---
type Props = {
	title?: string;
	description?: string;
	/** Ressource LCP probable (ex. hero) — améliore FCP/LCP sur la home */
	preloadLcpHref?: string;
	preloadLcpType?: string;
};

import CookieBanner from '../components/CookieBanner.astro';
import '@fontsource-variable/inter/wght.css';
import { SITE_ORIGIN } from '../config/site';

const {
	title = 'Emmanuel SAUVAGE — Consultant en optimisation d’outils digitaux',
	description = 'Audit, optimisation des processus, développement d’outils métier et automatisation des workflows pour améliorer l’efficacité opérationnelle des entreprises.',
	preloadLcpHref,
	preloadLcpType = 'image/svg+xml',
} = Astro.props;

function canonicalizePathname(pathname: string) {
	// Normalise les URL SEO : trailing slash sur les “pages” (sauf fichiers type .xml/.pdf)
	if (!pathname) return '/';
	if (pathname === '/') return '/';
	if (pathname.endsWith('/')) return pathname;
	if (/\.[a-z0-9]+$/i.test(pathname)) return pathname;
	return `${pathname}/`;
}

const canonicalPath = canonicalizePathname(Astro.url.pathname);
const canonicalUrl = `${SITE_ORIGIN}${canonicalPath}`;
---

<!doctype html>
<html lang="fr">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<link rel="icon" type="image/png" sizes="32x32" href="/images/favicon-32x32.png" />
		<link rel="icon" type="image/png" sizes="16x16" href="/images/favicon-16x16.png" />
		<link rel="apple-touch-icon" sizes="180x180" href="/images/apple-touch-icon.png" />
		<link rel="shortcut icon" href="/favicon.png" />
		<meta name="generator" content={Astro.generator} />
		{
			preloadLcpHref ? (
				<link rel="preload" href={preloadLcpHref} as="image" type={preloadLcpType} />
			) : null
		}
		<title>{title}</title>
		<meta name="description" content={description} />
		<link rel="canonical" href={canonicalUrl} />
		<meta property="og:url" content={canonicalUrl} />
		<slot name="head" />

		<!--
			Mesure d’audience : GTM + gtag.js — chargés uniquement après consentement « mesure d’audience » (RGPD).
			Si la même propriété GA4 (G-JV833GXDJL) est aussi déclenchée dans GTM, désactivez l’une des deux pour éviter le double comptage.
		-->
		<script is:inline>
			(function () {
				var gtmId = 'GTM-56RLPDSX';
				var gaMeasurementId = 'G-JV833GXDJL';

				window.dataLayer = window.dataLayer || [];

				var gtmLoaded = false;
				function loadGtm() {
					if (gtmLoaded) return;
					gtmLoaded = true;
					window.dataLayer.push({ 'gtm.start': new Date().getTime(), event: 'gtm.js' });
					var s = document.createElement('script');
					s.async = true;
					s.src = 'https://www.googletagmanager.com/gtm.js?id=' + gtmId;
					document.head.appendChild(s);
				}

				var gtagLoaded = false;
				function loadGtag() {
					if (gtagLoaded) return;
					gtagLoaded = true;
					function gtag() {
						dataLayer.push(arguments);
					}
					window.gtag = gtag;
					gtag('js', new Date());
					gtag('config', gaMeasurementId);
					var g = document.createElement('script');
					g.async = true;
					g.src = 'https://www.googletagmanager.com/gtag/js?id=' + encodeURIComponent(gaMeasurementId);
					document.head.appendChild(g);
				}

				function loadAnalytics() {
					loadGtm();
					loadGtag();
				}

				function hasAnalyticsConsent() {
					try {
						var raw = localStorage.getItem('es_cookie_consent_v1');
						var o = raw ? JSON.parse(raw) : null;
						return Boolean(o && o.analytics === true);
					} catch (e) {
						return false;
					}
				}

				if (hasAnalyticsConsent()) loadAnalytics();
				window.addEventListener('cookie-consent:change', function (ev) {
					if (ev.detail && ev.detail.analytics === true) loadAnalytics();
				});
			})();
		</script>
		<!-- End Google Tag Manager + gtag.js -->
	</head>
	<body>
		<!-- Google Tag Manager (noscript) -->
		<noscript>
			<iframe
				src="https://www.googletagmanager.com/ns.html?id=GTM-56RLPDSX"
				height="0"
				width="0"
				style="display:none;visibility:hidden"
				title="Google Tag Manager"></iframe>
		</noscript>
		<!-- End Google Tag Manager (noscript) -->

		<slot />
		<CookieBanner />
	</body>
</html>

<style>
	:root {
		/* Duo de couleurs : proposition 1 (bleu + orange) */
		--color-primary: #2f3a8f;
		--color-accent: #4f6ef7;
		/* Accent chaud : contraste avec le bleu, pour attirer l’œil (CTA, repères) */
		--color-spot: #c45c2e;
		--color-spot-hover: #a64d27;
		--color-spot-soft: rgba(196, 92, 46, 0.14);
		--color-text: #2d2d2d;
		--color-muted: #5b5b5b;
		--color-border: rgba(45, 45, 45, 0.12);
		--color-surface: #ffffff;
		--color-bg: #f7f8fc;
		--shadow-sm: 0 1px 2px rgba(16, 24, 40, 0.06);
		--shadow-md: 0 10px 30px rgba(16, 24, 40, 0.10);
		--radius: 16px;
	}

	html {
		/* Évite le débordement horizontal (blobs, grilles) → double barre / layout qui bouge */
		overflow-x: clip;
	}

	html,
	body {
		margin: 0;
		width: 100%;
		min-height: 100%;
	}

	body {
		background: var(--color-bg);
		color: var(--color-text);
		font-family: 'Inter Variable', Inter, ui-sans-serif, system-ui, -apple-system, 'Segoe UI', Roboto, Arial, sans-serif;
		line-height: 1.5;
		letter-spacing: -0.01em;
	}

	a {
		color: inherit;
	}

	:focus-visible {
		outline: 3px solid color-mix(in srgb, var(--color-spot) 55%, var(--color-accent));
		outline-offset: 2px;
	}

	::selection {
		background: color-mix(in srgb, var(--color-spot) 20%, transparent);
	}
</style>

<!-- CTA cohérents sur tout le site (les styles par page sont scoped, d’où !important ciblé) -->
<style is:global>
	a.nav__cta,
	.siteHeader__cta.nav__cta {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		text-decoration: none;
		padding: 10px 14px;
		border-radius: 12px;
		box-shadow: var(--shadow-sm);
		transition: transform 0.15s ease, box-shadow 0.15s ease;
		white-space: nowrap;
	}

	a.nav__cta:hover,
	.siteHeader__cta.nav__cta:hover {
		transform: translateY(-1px);
		box-shadow: var(--shadow-md);
	}

	a.button.button--primary,
	button.button.button--primary,
	a.nav__cta,
	.siteHeader__cta.nav__cta,
	.cookie .btn--primary,
	.prefs .btn--primary {
		overflow: hidden;
		background-clip: padding-box;
		border: 0 !important;
		background: linear-gradient(
			135deg,
			var(--color-primary) 0%,
			var(--color-spot) 70%,
			color-mix(in srgb, var(--color-spot) 85%, #ffffff) 100%
		) !important;
		color: #fff !important;
		border-color: transparent !important;
	}

	a.button.button--primary:hover,
	button.button.button--primary:hover,
	a.nav__cta:hover,
	.siteHeader__cta.nav__cta:hover,
	.cookie .btn--primary:hover,
	.prefs .btn--primary:hover {
		background: linear-gradient(
			135deg,
			var(--color-primary) 0%,
			var(--color-spot-hover) 70%,
			color-mix(in srgb, var(--color-spot-hover) 85%, #ffffff) 100%
		) !important;
	}

	/* CTA header : éviter une “marque” sombre sur le bord droit */
	.siteHeader__cta.nav__cta {
		overflow: hidden;
		background-clip: padding-box;
		border: 0 !important;
		background: linear-gradient(
			135deg,
			var(--color-primary) 0%,
			var(--color-spot) 70%,
			color-mix(in srgb, var(--color-spot) 85%, #ffffff) 100%
		) !important;
	}

	.siteHeader__cta.nav__cta:hover {
		background: linear-gradient(
			135deg,
			var(--color-primary) 0%,
			var(--color-spot-hover) 70%,
			color-mix(in srgb, var(--color-spot-hover) 85%, #ffffff) 100%
		) !important;
	}

	/* Pied de page (accueil, services, à propos, contact — même rendu « marque ») */
	.footer .container {
		width: min(1120px, calc(100% - 32px));
		margin: 0 auto;
	}

	@media (min-width: 521px) {
		.footer .container {
			width: min(1120px, calc(100% - 48px));
		}
	}

	.footer {
		padding: 32px 0 22px;
		border-top: 1px solid var(--color-border);
		background: rgba(247, 248, 251, 0.85);
	}

	.footer--brand {
		position: relative;
		margin-top: 0;
		padding-top: 40px;
		padding-bottom: 28px;
		border-top: none;
		background: linear-gradient(180deg, #e4e8f2 0%, #d8dce8 48%, #d2d7e5 100%);
		box-shadow:
			inset 0 1px 0 rgba(255, 255, 255, 0.65),
			0 -12px 32px rgba(47, 58, 143, 0.07);
	}

	.footer--brand::before {
		content: '';
		position: absolute;
		left: 0;
		right: 0;
		top: 0;
		height: 4px;
		background: linear-gradient(90deg, var(--color-primary) 0%, var(--color-spot) 55%, var(--color-accent) 100%);
		pointer-events: none;
	}

	.footer--brand .footer__bottom {
		border-top-color: rgba(45, 45, 45, 0.14);
	}

	.footer__grid {
		display: grid;
		grid-template-columns: 1.45fr repeat(5, minmax(0, 1fr));
		gap: 18px;
		align-items: start;
	}

	.footer__brand {
		display: inline-flex;
		align-items: center;
		gap: 8px;
		font-weight: 800;
		letter-spacing: -0.02em;
		color: var(--color-primary);
	}

	.footer__logoWrap {
		display: inline-flex;
		align-items: center;
		line-height: 0;
	}

	.footer__logo {
		display: block;
		width: 28px;
		height: 28px;
		border-radius: 8px;
		object-fit: cover;
	}

	.footer__text {
		color: var(--color-muted);
		opacity: 1;
		margin: 6px 0 0;
	}

	.footer__text a {
		color: inherit;
		text-decoration: none;
		font-weight: 600;
	}

	.footer__text a:hover {
		text-decoration: underline;
		text-decoration-color: rgba(47, 58, 143, 0.4);
	}

	.footer__title {
		font-weight: 700;
		margin-bottom: 10px;
	}

	.footer__links {
		list-style: none;
		padding: 0;
		margin: 0;
		display: grid;
		gap: 8px;
	}

	.footer__links a {
		color: var(--color-muted);
		text-decoration: none;
	}

	.footer__links a:hover {
		color: var(--color-text);
		text-decoration: underline;
		text-decoration-color: rgba(47, 58, 143, 0.4);
	}

	.footer__bottom {
		margin-top: 18px;
		padding-top: 16px;
		border-top: 1px solid var(--color-border);
		color: var(--color-muted);
		font-size: 14px;
	}

	.footer__bottom p {
		margin: 0;
	}

	@media (max-width: 980px) {
		.footer__grid {
			grid-template-columns: 1fr;
		}
	}
</style>

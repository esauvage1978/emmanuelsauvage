/** Carte (iframe) — centré sur Erquinghem-Lys, zoom adapté au périmètre d’environ 25 km. */
const zoneMapEmbedSrc =
	'https://maps.google.com/maps?q=Erquinghem-Lys%2C%2059193%20France&hl=fr&z=9&ie=UTF8&output=embed';
const zoneMapExternalHref =

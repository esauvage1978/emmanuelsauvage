---
/**
 * Liste du blog : `/blog` et `/blog/` (trailingSlash: 'ignore').
 * Articles : collection `blog` (`src/content/blog/*.md`) + `src/content.config.ts`.
 */
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import SiteHeader from '../../components/SiteHeader.astro';
import SiteFooter from '../../components/SiteFooter.astro';

const rawPosts = await getCollection('blog');
const posts = rawPosts
	.map((p) => ({
		slug: p.id,
		title: p.data.title,
		description: p.data.description,
		pubDate: p.data.pubDate,
		readingTimeMinutes: p.data.readingTimeMinutes,
		tags: p.data.tags,
	}))
	.sort((a, b) => b.pubDate.valueOf() - a.pubDate.valueOf());
---

<Layout
	title="Blog | Symfony, API, outils métier | Emmanuel SAUVAGE"
	description="Articles techniques : Symfony, API REST, validation, webhooks, Google Sheets et cadrage d’outils métier — contenu orienté praticiens et décideurs."
>
	<SiteHeader current="blog" />

	<main class="blogIndex">
		<div class="blogIndex__container">
			<header class="blogIndex__header">
				<h1>Blog</h1>
				<p>
					Notes de cadrage et d’implémentation : ce que je vérifie en mission sur Symfony, les API, la donnée et les
					outils internes.
				</p>
			</header>

			<ul class="blogIndex__list">
				{
					posts.map((post) => (
						<li>
							<article class="blogCard">
								<p class="blogCard__meta">
									<time datetime={post.pubDate.toISOString().slice(0, 10)}>{post.pubDate.toLocaleDateString('fr-FR', { dateStyle: 'long' })}</time>
									<span aria-hidden="true"> · </span>
									<span>{post.readingTimeMinutes} min</span>
								</p>
								<h2>
									<a href={`/blog/${post.slug}/`}>{post.title}</a>
								</h2>
								<p class="blogCard__desc">{post.description}</p>
								<ul class="blogCard__tags" aria-label="Thématiques">
									{post.tags.map((t) => (
										<li>{t}</li>
									))}
								</ul>
							</article>
						</li>
					))
				}
			</ul>
		</div>
	</main>

	<SiteFooter />
</Layout>

<style>
	.blogIndex {
		background: var(--color-bg);
		min-width: 0;
		overflow-x: clip;
	}

	.blogIndex__container {
		width: min(920px, calc(100% - 32px));
		margin: 0 auto;
		padding: 32px 0 72px;
	}

	@media (min-width: 521px) {
		.blogIndex__container {
			width: min(920px, calc(100% - 48px));
			padding-top: 40px;
		}
	}

	.blogIndex__header {
		max-width: 62ch;
		margin-bottom: 36px;
		padding-bottom: 24px;
		border-bottom: 1px solid color-mix(in srgb, var(--color-border) 78%, rgba(196, 92, 46, 0.12));
	}

	.blogIndex__header h1 {
		margin: 0 0 12px;
		font-size: clamp(1.75rem, 4vw, 2.35rem);
		letter-spacing: -0.03em;
		color: var(--color-primary);
	}

	.blogIndex__header p {
		margin: 0;
		line-height: 1.6;
		color: var(--color-muted);
		font-size: 1.05rem;
	}

	.blogIndex__list {
		list-style: none;
		padding: 0;
		margin: 0;
		display: grid;
		gap: 22px;
	}

	.blogCard {
		padding: 22px 22px 20px;
		border-radius: var(--radius);
		border: 1px solid var(--color-border);
		background: rgba(255, 255, 255, 0.92);
		box-shadow:
			inset 0 3px 0 0 rgba(196, 92, 46, 0.22),
			var(--shadow-sm);
		transition: box-shadow 0.18s ease, transform 0.18s ease;
	}

	.blogCard:hover {
		box-shadow:
			inset 0 3px 0 0 rgba(196, 92, 46, 0.32),
			var(--shadow-md);
		transform: translateY(-2px);
	}

	.blogCard__meta {
		margin: 0 0 8px;
		font-size: 13px;
		color: var(--color-muted);
	}

	.blogCard h2 {
		margin: 0 0 10px;
		font-size: 1.2rem;
		line-height: 1.25;
		letter-spacing: -0.02em;
	}

	.blogCard h2 a {
		color: var(--color-primary);
		text-decoration: none;
	}

	.blogCard h2 a:hover {
		text-decoration: underline;
		text-decoration-color: rgba(196, 92, 46, 0.45);
	}

	.blogCard__desc {
		margin: 0 0 14px;
		line-height: 1.55;
		color: var(--color-text);
		opacity: 0.92;
		font-size: 0.98rem;
	}

	.blogCard__tags {
		display: flex;
		flex-wrap: wrap;
		gap: 6px 10px;
		list-style: none;
		padding: 0;
		margin: 0;
		font-size: 11px;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.06em;
		color: var(--color-spot-hover);
	}
</style>

---
import Layout from '../layouts/Layout.astro';
import SiteHeader from '../components/SiteHeader.astro';
import SiteFooter from '../components/SiteFooter.astro';
import { GOOGLE_REVIEW_URL } from '../config/site';
---

<Layout
	title="Services | Emmanuel SAUVAGE"
	description="Développement PHP Symfony, front Vue.js/React, HTML/CSS, outils métier, automatisations, reporting (Google Sheets, Power BI, Looker) et formations sur mesure (Sheets, Excel)."
>
	<SiteHeader current="services" />

	<main class="page">
		<header class="page__head">
			<div class="page__headFx" aria-hidden="true">
				<div class="page__blob page__blob--a"></div>
				<div class="page__blob page__blob--spot"></div>
			</div>
			<div class="container">
				<p class="page__eyebrow">Services</p>
				<h1>
					Développement d’outils métier et <span class="page__h1Accent">applications web</span>
				</h1>
				<p class="lead">
					Je conçois et fais évoluer des applications de A à Z : back-end PHP/Symfony, interfaces Vue.js/React,
					intégrations et outillage data (Google Sheets, Power BI, Looker).
				</p>
			</div>
		</header>

		<section class="section">
			<div class="container cards">
				<article class="card">
					<h2>Développement back-end (PHP/Symfony)</h2>
					<p>
						Applications web, API, authentification, bases de données (MySQL), tests, performance et sécurité.
						Objectif : des bases solides et maintenables.
					</p>
				</article>
				<article class="card">
					<h2>Développement front (Vue.js / React)</h2>
					<p>
						Interfaces modernes en JavaScript : composants, formulaires, tableaux, intégration HTML/CSS et UX.
						Des écrans simples, rapides et efficaces.
					</p>
				</article>
				<article class="card">
					<h2>Outils métier &amp; automatisations</h2>
					<p>
						Automatisation des workflows, intégrations API, scripts, synchronisation d’outils et réduction des
						tâches répétitives.
					</p>
				</article>
				<article class="card">
					<h2>Data &amp; reporting</h2>
					<p>
						Tableaux de bord et pilotage : Google Sheets avancé (modèles, automatisations), Power BI et Looker
						pour des indicateurs fiables.
					</p>
				</article>
				<article class="card">
					<h2>Formation &amp; accompagnement</h2>
					<p>
						Les formations que je dispense portent pour l’essentiel sur <strong>Google Sheets</strong> et{' '}
						<strong>Excel</strong> : tableaux, formules, fiabilisation des données, automatisation simple quand c’est
						pertinent. Chaque session est <strong>sur mesure</strong> : je pars de la personne, de son contexte et de
						son besoin réel — idéalement de ses <strong>problématiques</strong> et de ses <strong>objectifs</strong> —
						pour construire un parcours adapté. Je préfère travailler sur des <strong>données ou fichiers de
						l’entreprise</strong> (anonymisés si besoin) : on progresse sur du concret, avec un impact direct sur le
						quotidien. En complément : accompagnement Symfony, bonnes pratiques web, documentation et transfert de
						compétences selon vos projets.
					</p>
				</article>
				<article class="card">
					<h2>Maintenance, dépannage &amp; optimisation</h2>
					<p>
						Résolution de problèmes techniques, optimisation des performances et amélioration continue des outils
						existants (qualité, stabilité, UX).
					</p>
				</article>
				<article class="card">
					<h2>Cadrage (audit) — si nécessaire</h2>
					<p>
						Quand le besoin est flou : analyse rapide, priorisation impact/effort, feuille de route. L’audit sert
						le développement, il ne le remplace pas.
					</p>
				</article>
			</div>
		</section>

		<!-- SEO uniquement : présent dans le HTML mais masqué visuellement -->
		<div class="queries__seo" aria-hidden="false">
			<h2>Requêtes courantes sur cette page</h2>
			<p>
				Les internautes recherchent notamment <strong>emmanuel sauvage</strong>, <strong>informaticien expert en
				dépannage</strong> et <strong>refonte Symfony</strong>. Ces demandes correspondent aux prestations
				résumées ci-dessus : développement back-end/front, outillage &amp; automatisations, data &amp;
				reporting, et maintenance/dépannage.
			</p>
		</div>

		<section class="cta page__preFooter" aria-label="Contact">
			<div class="container cta__inner cta__inner--accent">
				<div>
					<h2>Vous voulez clarifier vos priorités ?</h2>
					<p>Décrivez votre contexte et vos outils : je vous propose une première orientation.</p>
					<p class="cta__extra">
						Déjà client ?
						<a href={GOOGLE_REVIEW_URL} target="_blank" rel="noopener noreferrer">Laisser un avis Google</a>
					</p>
				</div>
				<div class="cta__actions">
					<a class="button button--primary" href="/contact">Prendre contact</a>
					<a class="button button--secondary" href="/">Retour à l’accueil</a>
				</div>
			</div>
		</section>
	</main>

	<SiteFooter />
</Layout>

<style>
	/* Mobile first */
	.container {
		width: min(1120px, calc(100% - 32px));
		margin: 0 auto;
	}

	@media (min-width: 521px) {
		.container {
			width: min(1120px, calc(100% - 48px));
		}
	}

	.page {
		padding-bottom: 32px;
		min-width: 0;
	}

	.page__head {
		position: relative;
		overflow: hidden;
		padding: 32px 0 20px;
		background: #fff;
		border-bottom: 1px solid var(--color-border);
	}

	@media (min-width: 768px) {
		.page__head {
			padding: 48px 0 20px;
		}
	}

	.page__headFx {
		position: absolute;
		inset: 0;
		pointer-events: none;
		z-index: 0;
	}

	.page__blob {
		position: absolute;
		border-radius: 999px;
		filter: blur(44px);
		opacity: 0.85;
		mix-blend-mode: multiply;
	}

	.page__blob--a {
		width: 280px;
		height: 280px;
		top: -120px;
		right: -80px;
		background: radial-gradient(circle at 40% 40%, rgba(79, 110, 247, 0.4), transparent 62%);
	}

	.page__blob--spot {
		width: 220px;
		height: 220px;
		bottom: -60px;
		left: -40px;
		background: radial-gradient(circle at 40% 40%, rgba(196, 92, 46, 0.35), transparent 62%);
	}

	.page__head .container {
		position: relative;
		z-index: 1;
	}

	.page__eyebrow {
		position: relative;
		margin: 0 0 10px;
		padding-left: 14px;
		font-size: 13px;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		color: color-mix(in srgb, var(--color-text) 72%, var(--color-spot));
	}

	.page__eyebrow::before {
		content: '';
		position: absolute;
		left: 0;
		top: 0.15em;
		bottom: 0.15em;
		width: 3px;
		border-radius: 2px;
		background: linear-gradient(180deg, var(--color-spot), var(--color-primary));
	}

	h1 {
		margin: 0 0 12px;
		font-size: clamp(1.65rem, 5vw, 2.75rem);
		line-height: 1.12;
		letter-spacing: -0.03em;
	}

	.page__h1Accent {
		background: linear-gradient(105deg, var(--color-primary) 0%, var(--color-spot) 100%);
		-webkit-background-clip: text;
		background-clip: text;
		color: transparent;
	}

	.lead {
		margin: 0;
		font-size: clamp(1rem, 2.8vw, 1.125rem);
		color: var(--color-muted);
		opacity: 1;
		max-width: 70ch;
		line-height: 1.55;
	}

	.section {
		padding: 20px 0 32px;
	}

	.queries__seo {
		position: absolute;
		width: 1px;
		height: 1px;
		padding: 0;
		margin: -1px;
		overflow: hidden;
		clip: rect(0, 0, 0, 0);
		white-space: nowrap;
		border: 0;
	}

	.cards {
		display: grid;
		grid-template-columns: 1fr;
		gap: 14px;
	}

	@media (min-width: 640px) {
		.cards {
			grid-template-columns: repeat(2, 1fr);
		}
	}

	.card {
		background: rgba(255, 255, 255, 0.96);
		border: 1px solid var(--color-border);
		border-radius: var(--radius);
		padding: 18px;
		box-shadow:
			inset 0 3px 0 0 rgba(196, 92, 46, 0.28),
			var(--shadow-sm);
		transition: box-shadow 0.18s ease, transform 0.18s ease;
	}

	.card:hover {
		box-shadow:
			inset 0 3px 0 0 rgba(196, 92, 46, 0.42),
			var(--shadow-md);
		transform: translateY(-2px);
	}

	h2 {
		margin: 0 0 10px;
		font-size: clamp(1.05rem, 2.5vw, 1.25rem);
		letter-spacing: -0.02em;
		color: var(--color-primary);
	}

	p {
		margin: 0;
		color: var(--color-text);
		opacity: 0.92;
		line-height: 1.5;
	}

	.button {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		text-decoration: none;
		border-radius: 14px;
		padding: 12px 16px;
		font-weight: 600;
		border: 1px solid transparent;
		transition: transform 0.15s ease, box-shadow 0.15s ease, background 0.15s ease, border 0.15s ease;
	}

	.button--primary {
		color: white;
		background: var(--color-primary);
		box-shadow: var(--shadow-sm);
	}

	.button--primary:hover {
		transform: translateY(-1px);
		box-shadow: var(--shadow-md);
	}

	.button--secondary {
		color: var(--color-text);
		background: rgba(255, 255, 255, 0.8);
		border-color: var(--color-border);
	}

	.button--secondary:hover {
		background: rgba(255, 255, 255, 1);
		transform: translateY(-1px);
		box-shadow: var(--shadow-sm);
	}

	.cta {
		padding: 8px 0;
	}

	.page__preFooter {
		padding-bottom: 56px;
		margin-bottom: 0;
		background: linear-gradient(180deg, transparent 0%, rgba(255, 255, 255, 0.75) 40%, #ffffff 100%);
		border-bottom: 1px solid rgba(47, 58, 143, 0.1);
	}

	.cta__inner {
		display: grid;
		grid-template-columns: 1fr;
		gap: 18px;
		align-items: center;
		padding: 22px;
		border-radius: 24px;
		border: 1px solid rgba(47, 58, 143, 0.2);
		background: linear-gradient(180deg, rgba(47, 58, 143, 0.1), rgba(255, 255, 255, 0.65));
		box-shadow: var(--shadow-md);
		min-width: 0;
		box-sizing: border-box;
	}

	/* Permet à la colonne des boutons de rétrécir sans déborder (grille CSS) */
	.cta__inner > * {
		min-width: 0;
	}

	.cta__inner--accent {
		border-color: color-mix(in srgb, var(--color-spot) 32%, rgba(47, 58, 143, 0.2));
		background: linear-gradient(
			135deg,
			rgba(47, 58, 143, 0.12),
			var(--color-spot-soft),
			rgba(79, 110, 247, 0.06)
		);
		box-shadow: 0 12px 40px rgba(47, 58, 143, 0.08), 0 0 0 1px rgba(196, 92, 46, 0.1);
	}

	.cta__extra {
		margin: 14px 0 0;
		font-size: 14px;
		color: var(--color-muted);
	}

	.cta__extra a {
		color: var(--color-spot-hover);
		font-weight: 600;
		text-decoration: underline;
		text-decoration-color: rgba(196, 92, 46, 0.35);
		text-underline-offset: 3px;
	}

	.cta__extra a:hover {
		color: var(--color-spot);
	}

	.cta__actions {
		display: flex;
		flex-direction: column;
		align-items: stretch;
		gap: 12px;
		width: 100%;
		max-width: 100%;
		min-width: 0;
		box-sizing: border-box;
	}

	.cta__actions .button {
		width: 100%;
		max-width: 100%;
		justify-content: center;
		box-sizing: border-box;
		white-space: normal;
		text-align: center;
		line-height: 1.35;
		padding-inline: 14px;
		overflow-wrap: break-word;
		hyphens: auto;
	}

	@media (min-width: 960px) {
		.cta__inner {
			grid-template-columns: minmax(0, 1.2fr) minmax(0, 0.85fr);
		}

		.cta__actions {
			flex-direction: row;
			flex-wrap: wrap;
			justify-content: flex-end;
			width: 100%;
			max-width: 100%;
		}

		.cta__actions .button {
			flex: 0 1 auto;
			min-width: 0;
			max-width: 100%;
			width: auto;
			white-space: nowrap;
			padding-inline: 16px;
		}
	}
</style>

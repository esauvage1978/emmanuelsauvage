---
import Layout from '../layouts/Layout.astro';
import SiteHeader from '../components/SiteHeader.astro';
import SiteFooter from '../components/SiteFooter.astro';
import { GOOGLE_REVIEW_URL } from '../config/site';
---

<Layout
	title="Optimisation et développement d’outils digitaux pour les entreprises | Emmanuel Sauvage"
	description="Consultant indépendant : audit outils digitaux entreprise, optimisation processus entreprise, développement d’outils métier et automatisation workflows. Audit, développement, formation et dépannage."
	preloadLcpHref="/images/hero-illustration-v2.svg"
>
	<SiteHeader current="home" />

	<main class="home">
		<section class="hero hero--impact" aria-label="Accroche">
			<div class="heroFx" aria-hidden="true">
				<div class="blob blob--a"></div>
				<div class="blob blob--b"></div>
				<div class="blob blob--c"></div>
				<div class="blob blob--spot" aria-hidden="true"></div>
				<svg class="grid" viewBox="0 0 1200 500" preserveAspectRatio="none">
					<defs>
						<linearGradient id="g" x1="0" y1="0" x2="1" y2="1">
							<stop offset="0" stop-color="rgba(79,110,247,0.35)" />
							<stop offset="0.5" stop-color="rgba(196,92,46,0.14)" />
							<stop offset="1" stop-color="rgba(47,58,143,0.18)" />
						</linearGradient>
					</defs>
					<path d="M0 420C220 320 360 360 540 260C720 160 880 240 1200 120V500H0Z" fill="url(#g)"></path>
				</svg>
			</div>
			<div class="container hero__grid hero__grid--impact">
				<div class="hero__content">
					<p class="eyebrow">Consultant indépendant — outils digitaux &amp; processus</p>
					<h1>Vos outils digitaux, <span class="h1Accent">plus simples et plus efficaces</span></h1>
					<p class="hero__subtitle hero__subtitle--short">
						L’idée, c’est que vos outils vous fassent gagner du temps — pas l’inverse.
					</p>

					<div class="hero__actions">
						<a class="button button--primary" href="#contact">Discuter de votre projet</a>
						<a class="button button--secondary" href="#services">Voir l’offre</a>
					</div>
				</div>

				<div class="hero__visual hero__visual--impact">
					<figure class="heroMedia heroMedia--impact">
						<img
							class="heroMedia__img"
							src="/images/hero-illustration-v2.svg"
							width="1400"
							height="933"
							alt="Illustration graphique : développement web, data et automatisation."
							loading="eager"
							fetchpriority="high"
						/>
						<figcaption class="srOnly">Illustration d’accueil.</figcaption>
					</figure>
				</div>
			</div>
		</section>

		<section id="services" class="homeSection homeSection--surface section section--alt" aria-labelledby="home-services-heading">
			<div class="container">
				<header class="homeSection__header">
					<p class="homeSection__rail" aria-hidden="true">
						<span class="homeSection__num">01</span>
						<span class="homeSection__label">Offre</span>
					</p>
					<div class="homeSection__intro">
						<h2 id="home-services-heading">Ce que je propose</h2>
						<p class="homeSection__lede">
							Applications Symfony, interfaces (Vue ou React), reporting, maintenance, formation… Les cartes
							donnent le fil. Pour les exemples et le déroulé concret, j’ai tout regroupé sur la page
							<a href="/services">Services</a>.
						</p>
					</div>
				</header>

				<div class="bento">
					<article class="bento__card bento__card--wide">
						<div class="bento__icon" aria-hidden="true">
							<svg viewBox="0 0 24 24" width="28" height="28">
								<path
									d="M4 4h16v14H4V4Zm3 17h10"
									fill="none"
									stroke="currentColor"
									stroke-width="2"
									stroke-linecap="round"
									stroke-linejoin="round"
								/>
								<path
									d="M8 8h8M8 11h6M8 14h5"
									fill="none"
									stroke="currentColor"
									stroke-width="2"
									stroke-linecap="round"
								/>
							</svg>
						</div>
						<h3>Applications Symfony</h3>
						<p>API, MySQL, sécurité, performance, mise en production.</p>
					</article>

					<article class="bento__card bento__card--wide">
						<div class="bento__icon" aria-hidden="true">
							<svg viewBox="0 0 24 24" width="28" height="28">
								<path
									d="M8 7h8M8 12h8M8 17h5"
									fill="none"
									stroke="currentColor"
									stroke-width="2"
									stroke-linecap="round"
								/>
								<path
									d="M6 3h12a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2Z"
									fill="none"
									stroke="currentColor"
									stroke-width="2"
									stroke-linejoin="round"
								/>
							</svg>
						</div>
						<h3>Interfaces Vue.js / React</h3>
						<p>Composants, formulaires, tableaux, UX soignée.</p>
					</article>

					<article class="bento__card">
						<div class="bento__icon bento__icon--sm" aria-hidden="true">
							<svg viewBox="0 0 24 24" width="24" height="24">
								<path d="M4 19V5m16 14V5" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
								<path d="M7 7h10M7 11h10M7 15h6" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
								<path d="M9 21h6" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
							</svg>
						</div>
						<h3>Data &amp; reporting</h3>
						<p>Sheets, Power BI, Looker, indicateurs actionnables.</p>
					</article>

					<article class="bento__card">
						<div class="bento__icon bento__icon--sm" aria-hidden="true">
							<svg viewBox="0 0 24 24" width="24" height="24">
								<path
									d="M12 2l3 7h7l-5.5 4.2L18.5 21 12 16.8 5.5 21l2-7.8L2 9h7l3-7Z"
									fill="none"
									stroke="currentColor"
									stroke-width="2"
									stroke-linejoin="round"
								/>
							</svg>
						</div>
						<h3>Maintenance &amp; optimisation</h3>
						<p>Fiabilité, perf, RGPD, évolutions progressives.</p>
					</article>

					<article class="bento__card">
						<div class="bento__icon bento__icon--sm" aria-hidden="true">
							<svg viewBox="0 0 24 24" width="24" height="24">
								<path d="M4 6h16M7 10h10M7 14h7" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
								<path
									d="M6 3h12a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2Z"
									fill="none"
									stroke="currentColor"
									stroke-width="2"
									stroke-linejoin="round"
								/>
							</svg>
						</div>
						<h3>Formation</h3>
						<p>Autonomie sur Symfony et bonnes pratiques web.</p>
					</article>
				</div>

				<p class="section__more">
					<a href="/services">Tout le détail des prestations →</a>
				</p>
			</div>
		</section>

		<section class="homeSection section" aria-labelledby="home-method-heading">
			<div class="container">
				<header class="homeSection__header">
					<p class="homeSection__rail" aria-hidden="true">
						<span class="homeSection__num">02</span>
						<span class="homeSection__label">Démarche</span>
					</p>
					<div class="homeSection__intro">
						<h2 id="home-method-heading">Comment on avance ensemble</h2>
						<p class="homeSection__lede">
							On commence par cadrer, on priorise, on met en œuvre, puis on veille à ce que vos équipes
							soient à l’aise avec le résultat. Envie d’en savoir plus sur mon parcours ou des références ?
							C’est par ici : <a href="/a-propos">À propos</a>.
						</p>
					</div>
				</header>

				<div class="steps">
					<article class="step">
						<div class="step__num" aria-hidden="true">01</div>
						<h3>Premier échange</h3>
						<p>Nous clarifions le contexte, les outils, les objectifs et les contraintes.</p>
					</article>
					<article class="step">
						<div class="step__num" aria-hidden="true">02</div>
						<h3>Audit &amp; plan d’action</h3>
						<p>Priorisation impact/effort, recommandations et feuille de route.</p>
					</article>
					<article class="step">
						<div class="step__num" aria-hidden="true">03</div>
						<h3>Mise en œuvre</h3>
						<p>Développement, intégrations, automatisations, sécurisation et documentation.</p>
					</article>
					<article class="step">
						<div class="step__num" aria-hidden="true">04</div>
						<h3>Adoption &amp; autonomie</h3>
						<p>Formation des équipes, transfert de compétences et amélioration continue.</p>
					</article>
				</div>

				<p class="homeSection__footerLink">
					<a href="/a-propos">Parcours, valeurs et références — page À propos →</a>
				</p>
			</div>
		</section>

		<section class="homeSection homeSection--surface section section--alt" aria-labelledby="home-proof-heading">
			<div class="container">
				<header class="homeSection__header">
					<p class="homeSection__rail" aria-hidden="true">
						<span class="homeSection__num">03</span>
						<span class="homeSection__label">Confiance</span>
					</p>
					<div class="homeSection__intro">
						<h2 id="home-proof-heading">Ce que disent les clients</h2>
						<p class="homeSection__lede">
							Des personnes avec qui j’ai travaillé ont pris le temps d’écrire ces quelques lignes. 
						</p>
					</div>
				</header>

				<div class="quotes quotes--full">
					<figure class="quote">
						<blockquote>
							« Nous avons sollicité Monsieur SAUVAGE, dans le cadre de la création de notre site WEB. Nous sommes
							extrêmement satisfaits de ses compétences, sa réactivité, sa patience et son analyse. Il est de très
							bon conseil. Je recommande vivement Monsieur SAUVAGE, expert dans son domaine. »
						</blockquote>
						<figcaption>— Maître Iwona Parafiniuk</figcaption>
					</figure>
					<figure class="quote">
						<blockquote>
							« J’ai sollicité Monsieur SAUVAGE pour la création d’une plateforme de formation en ligne. Il est
							pertinent, à l’écoute, patient et bienveillant. Je confirme qu’il est clairement dans son domaine. »
						</blockquote>
						<figcaption>— Laura Borges</figcaption>
					</figure>
					<figure class="quote">
						<blockquote>
							« Tout simplement remarquable ! Très compétent dans son domaine, avec une approche chaleureuse et
							humaine. Sa méthode donne vraiment envie de travailler. C’est un vrai plaisir d’apprendre à ses côtés. »
						</blockquote>
						<figcaption>— Axel Croce</figcaption>
					</figure>
				</div>

				<aside class="homeGoogleCta" aria-label="Invitation à laisser un avis sur Google">
					<p class="homeGoogleCta__eyebrow">En dehors de ces témoignages</p>
					<div class="googleReview googleReview--home">
						<p class="googleReview__text">
							Vous avez travaillé avec moi ? <strong>Un avis sur Google</strong> aide d’autres entreprises à
							mieux cerner mon accompagnement — merci d’avance.
						</p>
						<a
							class="button button--secondary googleReview__link"
							href={GOOGLE_REVIEW_URL}
							target="_blank"
							rel="noopener noreferrer"
						>
							Laisser un avis Google
						</a>
					</div>
				</aside>
			</div>
		</section>

		<section class="homeSeo" aria-label="Pour aller plus loin">
			<div class="container">
				<p class="homeSeo__text">
					<strong class="homeSeo__title">En savoir plus :</strong>
					<a href="/services">audit outils digitaux</a>, optimisation des processus et
					<a href="/services">développement Symfony, Vue.js et React</a> — détails sur la page
					<a href="/services">Services</a>, parcours sur <a href="/a-propos">À propos</a> et articles techniques sur le{' '}
					<a href="/blog">blog</a> (Symfony, API, outils métier).
				</p>
			</div>
		</section>

		<section id="contact" class="homeSection homeSection--ctaLast section cta" aria-labelledby="home-contact-heading">
			<div class="container">
				<header class="homeSection__header homeSection__header--cta">
					<p class="homeSection__rail" aria-hidden="true">
						<span class="homeSection__num">04</span>
						<span class="homeSection__label">Contact</span>
					</p>
					<div class="homeSection__intro">
						<h2 id="home-contact-heading">Parlons de votre contexte</h2>
						<p class="homeSection__lede">
							Un projet en tête, un outil qui coince, ou juste envie de voir si je peux aider ? Écrivez-moi
							— je réponds avec une première piste concrète.
						</p>
					</div>
				</header>

				<div class="cta__inner cta__inner--bold">
					<div>
						<p class="cta__lede cta__lede--strong">
							C’est sans engagement : formulaire sur la page contact, ou un simple message — vous choisissez.
						</p>
					</div>
					<div class="cta__actions">
						<a class="button button--primary" href="/contact">Prendre contact</a>
						<a class="button button--secondary" href="/services">Relire l’offre</a>
					</div>
				</div>
			</div>
		</section>
	</main>

	<SiteFooter discussHref="#contact" />
</Layout>

<style>
	.container {
		width: min(1120px, calc(100% - 32px));
		margin: 0 auto;
	}

	@media (min-width: 521px) {
		.container {
			width: min(1120px, calc(100% - 48px));
		}
	}

	main {
		display: block;
	}

	.hero {
		position: relative;
		overflow: hidden;
		padding: 48px 0 28px;
		background: white;
		border-bottom: 1px solid var(--color-border);
	}

	.hero--impact {
		padding: 56px 0 32px;
	}

	@media (min-width: 980px) {
		.hero {
			padding: 72px 0 36px;
		}

		.hero--impact {
			padding: 80px 0 48px;
		}
	}

	.heroFx {
		position: absolute;
		inset: 0;
		pointer-events: none;
		z-index: 0;
	}

	.blob {
		position: absolute;
		border-radius: 999px;
		filter: blur(40px);
		opacity: 0.95;
		mix-blend-mode: multiply;
	}

	.blob--a {
		width: 520px;
		height: 520px;
		top: -220px;
		left: -180px;
		background: radial-gradient(circle at 30% 30%, rgba(79, 110, 247, 0.55), rgba(79, 110, 247, 0) 60%),
			radial-gradient(circle at 70% 60%, rgba(47, 58, 143, 0.35), rgba(47, 58, 143, 0) 65%);
	}

	.blob--b {
		width: 560px;
		height: 560px;
		top: -260px;
		right: -260px;
		background: radial-gradient(circle at 40% 40%, rgba(47, 58, 143, 0.45), rgba(47, 58, 143, 0) 62%),
			radial-gradient(circle at 70% 70%, rgba(79, 110, 247, 0.38), rgba(79, 110, 247, 0) 66%);
	}

	.blob--c {
		width: 520px;
		height: 520px;
		bottom: -300px;
		left: 36%;
		background: radial-gradient(circle at 35% 35%, rgba(79, 110, 247, 0.35), rgba(79, 110, 247, 0) 62%),
			radial-gradient(circle at 70% 40%, rgba(47, 58, 143, 0.2), rgba(47, 58, 143, 0) 70%);
	}

	.home .blob--spot {
		width: 420px;
		height: 420px;
		bottom: -80px;
		right: -100px;
		opacity: 0.75;
		filter: blur(48px);
		mix-blend-mode: multiply;
		background: radial-gradient(circle at 40% 40%, rgba(196, 92, 46, 0.42), rgba(196, 92, 46, 0) 62%);
	}

	.grid {
		position: absolute;
		inset: auto 0 0 0;
		width: 100%;
		height: 220px;
		opacity: 0.9;
	}

	.hero__grid {
		display: grid;
		grid-template-columns: 1fr;
		gap: 28px;
		align-items: center;
		position: relative;
		z-index: 1;
		/* Permet aux colonnes de rétrécir sous la largeur du contenu (texte long, boutons) */
		min-width: 0;
	}

	.hero__grid--impact {
		align-items: center;
	}

	@media (min-width: 980px) {
		.hero__grid {
			grid-template-columns: 1.05fr 0.95fr;
			gap: 42px;
		}

		.hero__grid--impact {
			align-items: stretch;
		}
	}

	.hero__content {
		display: flex;
		flex-direction: column;
		align-items: center;
		text-align: center;
		min-width: 0;
		width: 100%;
		max-width: 100%;
		box-sizing: border-box;
	}

	@media (min-width: 980px) {
		.hero__content {
			align-items: stretch;
			text-align: left;
		}
	}

	.eyebrow {
		margin: 0 0 10px;
		color: var(--color-muted);
		font-size: 13px;
		letter-spacing: 0.08em;
		text-transform: uppercase;
	}

	.home .eyebrow {
		position: relative;
		padding-left: 0;
		color: color-mix(in srgb, var(--color-text) 72%, var(--color-spot));
	}

	.home .eyebrow::before {
		display: none;
	}

	@media (min-width: 980px) {
		.home .eyebrow {
			padding-left: 14px;
		}

		.home .eyebrow::before {
			display: block;
			content: '';
			position: absolute;
			left: 0;
			top: 0.15em;
			bottom: 0.15em;
			width: 3px;
			border-radius: 2px;
			background: linear-gradient(180deg, var(--color-spot), var(--color-primary));
		}
	}

	h1 {
		margin: 0 0 14px;
		font-size: clamp(36px, 4.8vw, 56px);
		line-height: 1.04;
		letter-spacing: -0.035em;
	}

	.h1Accent {
		background: linear-gradient(105deg, var(--color-primary) 0%, var(--color-spot) 100%);
		-webkit-background-clip: text;
		background-clip: text;
		color: transparent;
	}

	h2 {
		margin: 0 0 12px;
		font-size: clamp(26px, 3vw, 36px);
		letter-spacing: -0.02em;
		line-height: 1.15;
	}

	h3 {
		margin: 0 0 10px;
		font-size: 18px;
		letter-spacing: -0.01em;
	}

	p {
		margin: 0 0 12px;
		color: var(--color-text);
		opacity: 0.92;
	}

	.hero__subtitle {
		font-size: 18px;
		color: var(--color-muted);
		opacity: 1;
		max-width: 56ch;
	}

	.hero__subtitle--short {
		font-size: clamp(17px, 2vw, 20px);
		max-width: 42ch;
		line-height: 1.45;
		margin-inline: auto;
	}

	@media (min-width: 980px) {
		.hero__subtitle--short {
			margin-inline: 0;
		}
	}

	.hero__actions {
		display: flex;
		flex-direction: column;
		align-items: stretch;
		gap: 12px;
		margin-top: 22px;
		width: 100%;
		max-width: min(22rem, 100%);
		align-self: stretch;
		box-sizing: border-box;
		padding-inline: 0;
	}

	.hero__actions .button {
		width: 100%;
		max-width: 100%;
		justify-content: center;
		box-sizing: border-box;
		white-space: normal;
		text-align: center;
		line-height: 1.35;
		padding-inline: 14px;
		overflow-wrap: break-word;
		hyphens: auto;
	}

	@media (min-width: 980px) {
		.hero__actions {
			flex-direction: row;
			flex-wrap: wrap;
			justify-content: flex-start;
			width: auto;
			max-width: none;
			align-self: stretch;
		}

		.hero__actions .button {
			width: auto;
			max-width: none;
			white-space: nowrap;
			padding-inline: 16px;
		}
	}

	.button {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		gap: 10px;
		text-decoration: none;
		border-radius: 14px;
		padding: 12px 16px;
		font-weight: 600;
		border: 1px solid transparent;
		transition: transform 0.15s ease, box-shadow 0.15s ease, background 0.15s ease, border 0.15s ease;
	}

	.button--primary {
		color: white;
		background: var(--color-primary);
		box-shadow: var(--shadow-sm);
	}

	.button--primary:hover {
		transform: translateY(-1px);
		box-shadow: var(--shadow-md);
	}

	.button--secondary {
		color: var(--color-text);
		background: rgba(255, 255, 255, 0.8);
		border-color: var(--color-border);
	}

	.button--secondary:hover {
		background: rgba(255, 255, 255, 1);
		transform: translateY(-1px);
		box-shadow: var(--shadow-sm);
	}

	.home .button--secondary:hover {
		border-color: color-mix(in srgb, var(--color-spot) 45%, var(--color-border));
		box-shadow: 0 1px 2px rgba(16, 24, 40, 0.06), 0 0 0 1px rgba(196, 92, 46, 0.12);
	}

	.hero__visual {
		display: flex;
		justify-content: center;
		min-width: 0;
		max-width: 100%;
	}

	@media (min-width: 980px) {
		.hero__visual {
			justify-content: flex-end;
		}
	}

	.hero__visual--impact {
		align-items: center;
	}

	.heroMedia {
		margin: 0;
		width: min(560px, 100%);
		border-radius: 22px;
		overflow: hidden;
		border: 1px solid var(--color-border);
		box-shadow: var(--shadow-md);
		background: rgba(255, 255, 255, 0.85);
		position: relative;
	}

	.heroMedia--impact {
		width: min(620px, 100%);
		border-radius: 28px;
		box-shadow:
			0 24px 60px rgba(47, 58, 143, 0.16),
			0 0 0 1px rgba(196, 92, 46, 0.22),
			0 0 40px rgba(196, 92, 46, 0.08);
	}

	.heroMedia::after {
		content: '';
		position: absolute;
		inset: 0;

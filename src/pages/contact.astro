---
import Layout from '../layouts/Layout.astro';
import BrandLogo from '../components/BrandLogo.astro';
import SiteHeader from '../components/SiteHeader.astro';
import SiteFooter from '../components/SiteFooter.astro';
import { GOOGLE_REVIEW_URL } from '../config/site';

/** En dev : proxy Vite (astro.config). En prod (WAMP) : PHP dans public/. */
const contactSubmitUrl = import.meta.env.DEV ? '/api/zapier-contact' : '/contact-zapier.php';
---

<Layout
	title="Contact — diagnostic, audit ou mission | Emmanuel SAUVAGE"
	description="Contact entreprise : projet, budget envisagé, urgence et besoin. Réponse orientée ROI — Symfony, automatisation, Google Sheets, refonte web et audit d’outils digitaux."
>
	<SiteHeader current="contact" />

	<main class="contactPage">
		<section class="hero" aria-label="Contact">
			<div class="heroFx" aria-hidden="true">
				<div class="blob blob--a"></div>
				<div class="blob blob--b"></div>
				<div class="blob blob--c"></div>
				<div class="blob blob--spot"></div>
				<svg class="heroWave" viewBox="0 0 1200 500" preserveAspectRatio="none">
					<defs>
						<linearGradient id="contactGrad" x1="0" y1="0" x2="1" y2="1">
							<stop offset="0" stop-color="rgba(79,110,247,0.38)" />
							<stop offset="0.55" stop-color="rgba(196,92,46,0.22)" />
							<stop offset="1" stop-color="rgba(47,58,143,0.2)" />
						</linearGradient>
					</defs>
					<path
						d="M0 420C220 320 360 360 540 260C720 160 880 240 1200 120V500H0Z"
						fill="url(#contactGrad)"></path>
				</svg>
			</div>
			<div class="container hero__grid">
				<div class="hero__content">
					<p class="eyebrow contactEyebrow">Optimisation business · outils digitaux · processus</p>
					<h1>Un premier échange <span class="contactH1Accent">cadré</span> — budget, urgence, type de projet</h1>
					<p class="hero__subtitle">
						Vous décrivez votre contexte et vos contraintes ; je réponds avec une orientation réaliste (périmètre, risques,
						prochaine étape). Pas de promesse creuse : des priorités actionnables.
					</p>
					<ul class="trust">
						<li class="trust__item"><strong>ROI</strong> : gains, pertes, risques — pas seulement de la technique</li>
						<li class="trust__item"><strong>Stack</strong> : Symfony, API, automatisation, Sheets / data</li>
						<li class="trust__item"><strong>Terrain</strong> : organisations complexes, adoption, formation</li>
					</ul>
				</div>

				<div class="hero__visual">
					<figure class="heroMedia">
						<img
							class="heroMedia__img"
							src="/images/hero-illustration-v2.svg"
							width="1400"
							height="933"
							alt="Illustration : développement web, data et automatisation."
							loading="eager"
						/>
					</figure>
				</div>
			</div>
		</section>

		<section class="section section--alt" aria-label="Envoyer un message">
			<div class="container">
				<div class="section__head">
					<h2>Écrivez-moi en quelques lignes</h2>
					<p>
						Plus vous précisez outils, irritants et objectifs, plus la réponse sera utile — sans engagement.
					</p>
				</div>

				<div class="grid2">
					<form id="contact-form" class="form card" method="post" action="#" novalidate>
						<p id="form-status" class="formStatus" role="status" aria-live="polite" hidden></p>
						<input type="hidden" name="source" value="emmanuelsauvage" />
						<div class="field">
							<label for="name">Nom</label>
							<input id="name" name="name" autocomplete="name" required />
						</div>
						<div class="field">
							<label for="company">Entreprise</label>
							<input id="company" name="company" autocomplete="organization" />
						</div>
						<div class="field">
							<label for="email">Email</label>
							<input id="email" name="email" type="email" autocomplete="email" required />
						</div>
						<div class="field">
							<label for="objet">Objet de la sollicitation</label>
							<select id="objet" name="objet" required>
								<option value="" disabled selected>— Choisir un thème —</option>
								<option value="dev-symfony">Développement applicatif (Symfony, API)</option>
								<option value="front-vue-react">Interfaces web (Vue.js, React)</option>
								<option value="data-bi">Data, reporting &amp; BI (Sheets, Power BI, Looker…)</option>
								<option value="automation">Automatisation &amp; intégrations (API, outils métier…)</option>
								<option value="maintenance">Maintenance, audit ou refonte technique</option>
								<option value="formation">Formation ou accompagnement</option>
								<option value="autre">Autre</option>
							</select>
						</div>
						<div class="field">
							<label for="project-type">Type de projet (qualification)</label>
							<select id="project-type" name="project_type" required>
								<option value="" disabled selected>— Préciser le type —</option>
								<option value="audit-diagnostic">Audit / diagnostic / cadrage</option>
								<option value="refonte-evolution">Refonte ou évolution d’outil métier</option>
								<option value="automation-integration">Automatisation / intégrations</option>
								<option value="data-reporting">Data, reporting, Google Sheets / BI</option>
								<option value="maintenance-support">Maintenance, perf, sécurité</option>
								<option value="formation">Formation / montée en compétences</option>
								<option value="autre-projet">Autre / à définir</option>
							</select>
						</div>
						<div class="field">
							<label for="budget-range">Budget envisagé (ordre de grandeur)</label>
							<select id="budget-range" name="budget_range" required>
								<option value="" disabled selected>— Indiquer une fourchette —</option>
								<option value="under-3k">&lt; 3 k€</option>
								<option value="3k-8k">3 k€ — 8 k€</option>
								<option value="8k-20k">8 k€ — 20 k€</option>
								<option value="20k-50k">20 k€ — 50 k€</option>
								<option value="50k-plus">50 k€ et +</option>
								<option value="unknown">À définir avec vous</option>
							</select>
						</div>
						<div class="field">
							<label for="urgency">Urgence / échéance</label>
							<select id="urgency" name="urgency" required>
								<option value="" disabled selected>— Choisir —</option>
								<option value="asap">Critique (&lt; 2 semaines)</option>
								<option value="month">Court terme (2 à 6 semaines)</option>
								<option value="quarter">Moyen terme (1 à 3 mois)</option>
								<option value="later">Plus tard / planification</option>
							</select>
						</div>
						<div class="field">
							<label for="message">Message</label>
							<textarea
								id="message"
								name="message"
								rows="6"
								placeholder="Ex. : refonte d’un outil Symfony, tableau de bord Power BI, automatisation Google Sheets, intégration API…"
								required
							></textarea>
						</div>
						<button class="button button--primary" id="contact-submit" type="submit">Envoyer le message</button>
						<div class="consent">
							<label class="consent__label">
								<input
									class="consent__checkbox"
									id="privacy-policy"
									name="privacy_policy_accepted"
									type="checkbox"
									value="true"
									required
								/>
								<span>
									J’ai lu la <a href="/politique-de-confidentialite">politique de confidentialité</a> et j’accepte que
									mes données soient utilisées pour répondre à ma demande.
								</span>
							</label>
						</div>
						<p class="hint">
							Indiquez si possible : outils actuels (ERP, CRM, fichiers, SaaS), volume / fréquence, risques ou irritants
							majeurs — et ce qu’un « succès » changerait concrètement pour votre activité.
						</p>
					</form>

					<aside class="side">
						<div class="callout">
							<h3>Pour une réponse efficace</h3>
							<ul class="checklist">
								<li>Quels systèmes ou fichiers sont concernés ?</li>
								<li>Où perdez-vous du temps aujourd’hui ?</li>
								<li>Résultat attendu : délai, fiabilité, automatisation, reporting…</li>
							</ul>
						</div>

						<div class="card">
							<h3>Coordonnées</h3>
							<p class="card__text">
								<a href="tel:+33609924945">06 09 92 49 45</a><br />
								Erquinghem-lys<br />
								<a href="mailto:contact@emmanuelsauvage.fr">contact@emmanuelsauvage.fr</a>
							</p>
						</div>

						<div class="card card--accent">
							<h3>Services</h3>
							<p class="card__text">
								Développement Symfony • interfaces Vue.js / React • data &amp; reporting • automatisation • formation.
							</p>
							<a class="button button--secondary" href="/services">Voir les services</a>
						</div>

						<div class="card googleReviewCard">
							<h3>Avis Google</h3>
							<p class="card__text">
								Après une collaboration, vous pouvez laisser un avis — c’est rapide et ça aide les prochains clients.
							</p>
							<a
								class="button button--secondary"
								href={GOOGLE_REVIEW_URL}
								target="_blank"
								rel="noopener noreferrer"
							>
								Laisser un avis Google
							</a>
						</div>
					</aside>
				</div>
			</div>
		</section>

		<section class="section cta" aria-label="Poursuivre">
			<div class="container cta__inner cta__inner--accent">
				<div>
					<h2>Envie d’explorer avant d’écrire ?</h2>
					<p>
						La page services détaille les offres : développement d’applications, front-end, data, maintenance et
						formation.
					</p>
				</div>
				<div class="cta__actions">
					<a class="button button--primary" href="/services">Découvrir les services</a>
					<a class="button button--secondary" href="/a-propos">À propos</a>
				</div>
			</div>
		</section>
	</main>

	<SiteFooter />

	<script define:vars={{ contactSubmitUrl }}>
		(() => {
			const form = document.getElementById('contact-form');
			const statusEl = document.getElementById('form-status');
			const submitBtn = document.getElementById('contact-submit');
			if (!form || !statusEl || !submitBtn) return;

			const setStatus = (type, text) => {
				statusEl.hidden = false;
				statusEl.textContent = text;
				statusEl.classList.remove('formStatus--ok', 'formStatus--err');
				statusEl.classList.add(type === 'ok' ? 'formStatus--ok' : 'formStatus--err');
			};

			form.addEventListener('submit', async (e) => {
				e.preventDefault();
				statusEl.hidden = true;
				statusEl.textContent = '';

				const consent = form.querySelector('.consent__checkbox');
				if (consent && !consent.checked) {
					setStatus('err', 'Veuillez accepter la politique de confidentialité pour envoyer le message.');
					return;
				}

				const nowIso = new Date().toISOString();
				const name = document.getElementById('name')?.value?.trim() ?? '';
				const company = document.getElementById('company')?.value?.trim() ?? '';
				const email = document.getElementById('email')?.value?.trim() ?? '';
				const objetSelect = document.getElementById('objet');
				const objet = objetSelect?.value?.trim() ?? '';
				const objetLabel = objetSelect?.selectedOptions?.[0]?.textContent?.trim() ?? '';
				const projectTypeSelect = document.getElementById('project-type');
				const projectType = projectTypeSelect?.value?.trim() ?? '';
				const projectTypeLabel = projectTypeSelect?.selectedOptions?.[0]?.textContent?.trim() ?? '';
				const budgetSelect = document.getElementById('budget-range');
				const budgetRange = budgetSelect?.value?.trim() ?? '';
				const budgetRangeLabel = budgetSelect?.selectedOptions?.[0]?.textContent?.trim() ?? '';
				const urgencySelect = document.getElementById('urgency');
				const urgency = urgencySelect?.value?.trim() ?? '';
				const urgencyLabel = urgencySelect?.selectedOptions?.[0]?.textContent?.trim() ?? '';
				const message = document.getElementById('message')?.value?.trim() ?? '';
				const source =
					form.querySelector('input[name="source"]')?.value?.trim() || 'emmanuelsauvage';
				const page = typeof window !== 'undefined' ? window.location.href : '';

				if (
					!name ||
					!email ||
					!objet ||
					!message ||
					!projectType ||
					!budgetRange ||
					!urgency
				) {
					setStatus(
						'err',
						'Merci de remplir tous les champs obligatoires (y compris qualification projet, budget et urgence).',
					);
					return;
				}

				submitBtn.disabled = true;
				const prevLabel = submitBtn.textContent;
				submitBtn.textContent = 'Envoi en cours…';

				const payload = {
					name,
					company: company || '—',
					email,
					objet,
					objet_label: objetLabel || objet,
					project_type: projectType,
					project_type_label: projectTypeLabel || projectType,
					budget_range: budgetRange,
					budget_range_label: budgetRangeLabel || budgetRange,
					urgency,
					urgency_label: urgencyLabel || urgency,
					message,
					source,
					page,
					privacy_policy_accepted: true,
					privacy_policy_accepted_at: nowIso,
					submitted_at: nowIso,
				};

				try {
					const res = await fetch(contactSubmitUrl, {
						method: 'POST',
						headers: { 'Content-Type': 'application/json' },
						body: JSON.stringify(payload),
					});
					const data = await res.json().catch(() => ({}));
					if (!res.ok) {
						const detail =
							typeof data?.error === 'string' ? ` (${data.error})` : data?.message ? ` (${data.message})` : '';
						throw new Error((res.statusText || 'Erreur') + detail);
					}
					if (data.status === 'success' || data.ok === true || (res.ok && data.attempt != null)) {
						setStatus('ok', 'Merci ! Votre message a bien été envoyé. Je vous réponds dès que possible.');
						form.reset();
					} else {
						throw new Error('Réponse inattendue du serveur');
					}
				} catch (err) {
					console.error('[contact]', err);
					const isNetwork =
						err instanceof TypeError ||
						(err instanceof Error && /failed to fetch|networkerror|load failed/i.test(err.message));
					setStatus(
						'err',
						isNetwork
							? "Connexion impossible (réseau ou serveur). Si vous testez en local sans WAMP, lancez « npm run dev » (proxy intégré) ou déployez le site avec PHP. Sinon écrivez à contact@emmanuelsauvage.fr."
							: "L'envoi a échoué. Réessayez plus tard ou écrivez-moi à contact@emmanuelsauvage.fr.",
					);
				} finally {
					submitBtn.disabled = false;
					submitBtn.textContent = prevLabel;
				}
			});
		})();
	</script>
</Layout>

<style>
	.container {
		width: min(1120px, calc(100% - 32px));
		margin: 0 auto;
	}

	@media (min-width: 521px) {
		.container {
			width: min(1120px, calc(100% - 48px));
		}
	}

	main.contactPage {
		display: block;
		min-width: 0;
		overflow-x: clip;
	}

	.hero {
		position: relative;
		overflow: hidden;
		padding: 56px 0 40px;
		background: linear-gradient(
			165deg,
			#ffffff 0%,
			rgba(247, 248, 252, 0.98) 42%,
			color-mix(in srgb, var(--color-spot-soft) 55%, #ffffff) 100%
		);
		border-bottom: 1px solid color-mix(in srgb, var(--color-border) 70%, rgba(196, 92, 46, 0.12));
	}

	.heroFx {
		position: absolute;
		inset: 0;
		pointer-events: none;
		z-index: 0;
	}

	.blob {
		position: absolute;
		border-radius: 999px;
		filter: blur(40px);
		opacity: 0.95;
		mix-blend-mode: multiply;
	}

	.blob--a {
		width: 520px;
		height: 520px;
		top: -220px;
		left: -180px;
		background: radial-gradient(circle at 30% 30%, rgba(79, 110, 247, 0.55), rgba(79, 110, 247, 0) 60%),
			radial-gradient(circle at 70% 60%, rgba(47, 58, 143, 0.35), rgba(47, 58, 143, 0) 65%);
	}

	.blob--b {
		width: 560px;
		height: 560px;
		top: -260px;
		right: -260px;
		background: radial-gradient(circle at 40% 40%, rgba(47, 58, 143, 0.45), rgba(47, 58, 143, 0) 62%),
			radial-gradient(circle at 70% 70%, rgba(79, 110, 247, 0.38), rgba(79, 110, 247, 0) 66%);
	}

	.blob--c {
		width: 520px;
		height: 520px;
		bottom: -300px;
		left: 36%;
		background: radial-gradient(circle at 35% 35%, rgba(79, 110, 247, 0.32), rgba(79, 110, 247, 0) 62%),
			radial-gradient(circle at 70% 40%, rgba(196, 92, 46, 0.16), rgba(47, 58, 143, 0) 70%);
	}

	.blob--spot {
		width: 360px;
		height: 360px;
		bottom: -120px;
		right: 6%;
		background: radial-gradient(circle at 45% 45%, rgba(196, 92, 46, 0.4), rgba(196, 92, 46, 0) 62%);
		mix-blend-mode: multiply;
	}

	.heroWave {
		position: absolute;
		inset: auto 0 0 0;
		width: 100%;
		height: 220px;
		opacity: 0.9;
	}

	.hero__grid {
		display: grid;
		grid-template-columns: 1fr;
		gap: 28px;
		align-items: center;
		position: relative;
		z-index: 1;
		min-width: 0;
	}

	@media (min-width: 981px) {
		.hero__grid {
			grid-template-columns: 1.05fr 0.95fr;
			gap: 42px;
		}
	}

	.eyebrow {
		margin: 0 0 10px;
		color: var(--color-muted);
		font-size: 14px;
		letter-spacing: 0.06em;
		text-transform: uppercase;
	}

	.contactEyebrow {
		position: relative;
		padding-left: 14px;
		color: color-mix(in srgb, var(--color-text) 70%, var(--color-spot));
	}

	.contactEyebrow::before {
		content: '';
		position: absolute;
		left: 0;
		top: 0.15em;
		bottom: 0.15em;
		width: 3px;
		border-radius: 2px;
		background: linear-gradient(180deg, var(--color-spot), var(--color-primary));
	}

	h1 {
		margin: 0 0 14px;
		font-size: clamp(30px, 4vw, 48px);
		line-height: 1.08;
		letter-spacing: -0.03em;
	}

	.contactH1Accent {
		background: linear-gradient(105deg, var(--color-primary) 0%, var(--color-spot) 100%);
		-webkit-background-clip: text;
		background-clip: text;
		color: transparent;
	}

	h2 {
		margin: 0 0 12px;
		font-size: clamp(26px, 3vw, 36px);
		letter-spacing: -0.02em;
		line-height: 1.15;
		color: var(--color-primary);
	}

	h3 {
		margin: 0 0 10px;
		font-size: 18px;
		letter-spacing: -0.01em;
		color: var(--color-primary);
	}

	.hero__subtitle {
		margin: 0;
		font-size: 18px;
		color: var(--color-muted);
		opacity: 1;
		max-width: 56ch;
	}

	.trust {
		list-style: none;
		padding: 0;
		margin: 22px 0 0;
		display: grid;
		gap: 8px;
	}

	.trust__item {
		color: var(--color-muted);
		background: rgba(255, 255, 255, 0.88);
		border: 1px solid color-mix(in srgb, var(--color-border) 82%, rgba(47, 58, 143, 0.1));
		border-radius: 14px;
		padding: 10px 12px;
		box-shadow: var(--shadow-sm);
	}

	.trust__item:nth-child(2) {
		border-color: color-mix(in srgb, var(--color-border) 70%, rgba(196, 92, 46, 0.22));
		box-shadow:
			inset 3px 0 0 0 rgba(196, 92, 46, 0.35),
			var(--shadow-sm);
	}

	.trust__item:nth-child(3) {
		border-color: color-mix(in srgb, var(--color-border) 75%, rgba(79, 110, 247, 0.2));
		box-shadow:
			inset 3px 0 0 0 rgba(79, 110, 247, 0.35),
			var(--shadow-sm);
	}

	.trust__item strong {
		color: color-mix(in srgb, var(--color-primary) 50%, var(--color-spot-hover));
	}

	.hero__visual {
		display: flex;
		justify-content: center;
		min-width: 0;
	}

	@media (min-width: 981px) {
		.hero__visual {
			justify-content: flex-end;
		}
	}

	.heroMedia {
		margin: 0;
		width: min(520px, 100%);
		border-radius: 22px;
		overflow: hidden;
		border: 1px solid color-mix(in srgb, var(--color-border) 75%, rgba(196, 92, 46, 0.18));
		box-shadow:
			0 12px 40px rgba(47, 58, 143, 0.1),
			0 0 0 1px rgba(196, 92, 46, 0.12);
		background: rgba(255, 255, 255, 0.9);
		position: relative;
	}

	.heroMedia::after {
		content: '';
		position: absolute;
		inset: 0;
		background: linear-gradient(180deg, rgba(47, 58, 143, 0) 40%, rgba(47, 58, 143, 0.12) 100%);
		pointer-events: none;
	}

	.heroMedia__img {
		display: block;
		width: 100%;
		height: auto;
		transform: scale(1.02);
	}

	.section {
		padding: 56px 0;
	}

	.section--alt {
		background: linear-gradient(
			180deg,
			rgba(255, 255, 255, 0.92) 0%,
			color-mix(in srgb, var(--color-bg) 92%, var(--color-spot-soft)) 48%,
			rgba(255, 255, 255, 0.88) 100%
		);
		border-top: 1px solid color-mix(in srgb, var(--color-border) 75%, rgba(196, 92, 46, 0.1));
		border-bottom: 1px solid color-mix(in srgb, var(--color-border) 75%, rgba(79, 110, 247, 0.08));
	}

	.section__head {
		display: grid;
		gap: 10px;
		margin-bottom: 22px;
		max-width: 62ch;
	}

	.section__head h2 {
		position: relative;
		padding-bottom: 12px;
	}

	.section__head h2::after {
		content: '';
		position: absolute;
		left: 0;
		bottom: 0;
		width: 52px;
		height: 3px;
		border-radius: 2px;
		background: linear-gradient(90deg, var(--color-spot), var(--color-accent));
	}

	.section__head p {
		margin: 0;
		color: var(--color-muted);
		opacity: 1;
		font-size: 17px;
	}

	.grid2 {
		display: grid;
		grid-template-columns: minmax(0, 1.1fr) minmax(0, 0.9fr);
		gap: 28px;
		align-items: start;
		min-width: 0;
	}


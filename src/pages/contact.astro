---
import Layout from '../layouts/Layout.astro';
import BrandLogo from '../components/BrandLogo.astro';
import { GOOGLE_REVIEW_URL } from '../config/site';

/** En dev : proxy Vite (astro.config). En prod (WAMP) : PHP dans public/. */
const contactSubmitUrl = import.meta.env.DEV ? '/api/zapier-contact' : '/contact-zapier.php';
---

<Layout
	title="Contact | Emmanuel Sauvage"
	description="Contactez Emmanuel Sauvage : développement Symfony, Vue.js, React, automatisation et reporting (Sheets, Power BI, Looker) pour votre entreprise."
>
	<header class="header">
		<div class="container header__inner">
			<a class="brand" href="/">
				<span class="brand__logoWrap" aria-hidden="true">
					<BrandLogo variant="header" class="brand__logo" />
				</span>
				<span class="brand__text">Emmanuel Sauvage</span>
			</a>

			<nav class="nav" aria-label="Navigation principale">
				<a class="nav__link" href="/services">Services</a>
				<a class="nav__link" href="/a-propos">À propos</a>
				<a class="nav__link nav__link--current" href="/contact" aria-current="page">Contact</a>
				<a class="nav__cta" href="/#contact">Discuter de votre projet</a>
			</nav>
		</div>
	</header>

	<main>
		<section class="hero" aria-label="Contact">
			<div class="heroFx" aria-hidden="true">
				<div class="blob blob--a"></div>
				<div class="blob blob--b"></div>
				<div class="blob blob--c"></div>
				<svg class="heroWave" viewBox="0 0 1200 500" preserveAspectRatio="none">
					<defs>
						<linearGradient id="contactGrad" x1="0" y1="0" x2="1" y2="1">
							<stop offset="0" stop-color="rgba(79,110,247,0.35)" />
							<stop offset="1" stop-color="rgba(47,58,143,0.18)" />
						</linearGradient>
					</defs>
					<path
						d="M0 420C220 320 360 360 540 260C720 160 880 240 1200 120V500H0Z"
						fill="url(#contactGrad)"></path>
				</svg>
			</div>
			<div class="container hero__grid">
				<div class="hero__content">
					<a class="backLink" href="/" aria-label="Retour à l’accueil">← Retour à l’accueil</a>
					<p class="eyebrow">Développement web • Symfony • Vue.js • React</p>
					<h1>Parlons de vos outils et de vos processus</h1>
					<p class="hero__subtitle">
						Expliquez votre contexte : applications métier, interfaces, automatisation ou reporting — je vous réponds
						avec une première piste concrète.
					</p>
					<ul class="trust">
						<li class="trust__item"><strong>Fullstack</strong> : de l’API à l’interface</li>
						<li class="trust__item"><strong>Stack</strong> : PHP, Symfony, JavaScript, MySQL</li>
						<li class="trust__item"><strong>Data</strong> : Google Sheets, Power BI, Looker</li>
					</ul>
				</div>

				<div class="hero__visual">
					<figure class="heroMedia">
						<img
							class="heroMedia__img"
							src="/images/hero-illustration-v2.svg"
							width="1400"
							height="933"
							alt="Illustration : développement web, data et automatisation."
							loading="eager"
						/>
					</figure>
				</div>
			</div>
		</section>

		<section class="section section--alt" aria-label="Envoyer un message">
			<div class="container">
				<div class="section__head">
					<h2>Écrivez-moi en quelques lignes</h2>
					<p>
						Plus vous précisez outils, irritants et objectifs, plus la réponse sera utile — sans engagement.
					</p>
				</div>

				<div class="grid2">
					<form id="contact-form" class="form card" method="post" action="#" novalidate>
						<p id="form-status" class="formStatus" role="status" aria-live="polite" hidden></p>
						<div class="field">
							<label for="name">Nom</label>
							<input id="name" name="name" autocomplete="name" required />
						</div>
						<div class="field">
							<label for="company">Entreprise</label>
							<input id="company" name="company" autocomplete="organization" />
						</div>
						<div class="field">
							<label for="email">Email</label>
							<input id="email" name="email" type="email" autocomplete="email" required />
						</div>
						<div class="field">
							<label for="message">Message</label>
							<textarea
								id="message"
								name="message"
								rows="6"
								placeholder="Ex. : refonte d’un outil Symfony, tableau de bord Power BI, automatisation Google Sheets, intégration API…"
								required
							></textarea>
						</div>
						<button class="button button--primary" id="contact-submit" type="submit">Envoyer le message</button>
						<div class="consent">
							<label class="consent__label">
								<input class="consent__checkbox" type="checkbox" required />
								<span>
									J’ai lu la <a href="/politique-de-confidentialite">politique de confidentialité</a> et j’accepte que
									mes données soient utilisées pour répondre à ma demande.
								</span>
							</label>
						</div>
						<p class="hint">
							Indiquez si possible : outils actuels (ERP, CRM, fichiers, SaaS), volume / fréquence, et le délai souhaité.
						</p>
					</form>

					<aside class="side">
						<div class="callout">
							<h3>Pour une réponse efficace</h3>
							<ul class="checklist">
								<li>Quels systèmes ou fichiers sont concernés ?</li>
								<li>Où perdez-vous du temps aujourd’hui ?</li>
								<li>Résultat attendu : délai, fiabilité, automatisation, reporting…</li>
							</ul>
						</div>

						<div class="card">
							<h3>Coordonnées</h3>
							<p class="card__text">
								<a href="tel:+33609924945">06 09 92 49 45</a><br />
								Erquinghem-lys<br />
								<a href="mailto:contact@emmanuelsauvage.fr">contact@emmanuelsauvage.fr</a>
							</p>
						</div>

						<div class="card card--accent">
							<h3>Services</h3>
							<p class="card__text">
								Développement Symfony • interfaces Vue.js / React • data &amp; reporting • automatisation • formation.
							</p>
							<a class="button button--secondary" href="/services">Voir les services</a>
						</div>

						<div class="card googleReviewCard">
							<h3>Avis Google</h3>
							<p class="card__text">
								Après une collaboration, vous pouvez laisser un avis — c’est rapide et ça aide les prochains clients.
							</p>
							<a
								class="button button--secondary"
								href={GOOGLE_REVIEW_URL}
								target="_blank"
								rel="noopener noreferrer"
							>
								Laisser un avis Google
							</a>
						</div>
					</aside>
				</div>
			</div>
		</section>

		<section class="section cta" aria-label="Poursuivre">
			<div class="container cta__inner">
				<div>
					<h2>Envie d’explorer avant d’écrire ?</h2>
					<p>
						La page services détaille les offres : développement d’applications, front-end, data, maintenance et
						formation.
					</p>
				</div>
				<div class="cta__actions">
					<a class="button button--primary" href="/services">Découvrir les services</a>
					<a class="button button--secondary" href="/a-propos">À propos</a>
				</div>
			</div>
		</section>
	</main>

	<footer class="footer" aria-label="Pied de page">
		<div class="container footer__grid">
			<div>
				<div class="footer__brand">
					<span class="footer__logoWrap" aria-hidden="true">
						<BrandLogo variant="footer" class="footer__logo" />
					</span>
					<span>Emmanuel Sauvage</span>
				</div>
				<p class="footer__text">Consultant indépendant — optimisation des outils digitaux et des processus.</p>
				<p class="footer__text">
					<a href="mailto:contact@emmanuelsauvage.fr">contact@emmanuelsauvage.fr</a>
				</p>
				<p class="footer__text">
					<a href="tel:+33609924945">06 09 92 49 45</a> · Erquinghem-lys
				</p>
			</div>

			<div>
				<div class="footer__title">Navigation</div>
				<ul class="footer__links">
					<li><a href="/services">Services</a></li>
					<li><a href="/a-propos">À propos</a></li>
					<li><a href="/contact">Contact</a></li>
				</ul>
			</div>

			<div>
				<div class="footer__title">Coordonnées</div>
				<ul class="footer__links">
					<li><a href="/contact">Formulaire de contact</a></li>
					<li><a href="/#contact">Discuter de votre projet</a></li>
					<li>
						<a href={GOOGLE_REVIEW_URL} target="_blank" rel="noopener noreferrer">Laisser un avis Google</a>
					</li>
				</ul>
			</div>
			<div>
				<div class="footer__title">Légal</div>
				<ul class="footer__links">
					<li><a href="/mentions-legales">Mentions légales</a></li>
					<li><a href="/politique-de-confidentialite">Politique de confidentialité</a></li>
					<li><a href="/cgu">CGU</a></li>
					<li><a href="/cgv">CGV</a></li>
					<li><a href="/cookies">Cookies</a></li>
				</ul>
			</div>
		</div>
		<div class="container footer__bottom">
			<p>© {new Date().getFullYear()} Emmanuel Sauvage — Tous droits réservés.</p>
		</div>
	</footer>

	<script define:vars={{ contactSubmitUrl }}>
		(() => {
			const form = document.getElementById('contact-form');
			const statusEl = document.getElementById('form-status');
			const submitBtn = document.getElementById('contact-submit');
			if (!form || !statusEl || !submitBtn) return;

			const setStatus = (type, text) => {
				statusEl.hidden = false;
				statusEl.textContent = text;
				statusEl.classList.remove('formStatus--ok', 'formStatus--err');
				statusEl.classList.add(type === 'ok' ? 'formStatus--ok' : 'formStatus--err');
			};

			form.addEventListener('submit', async (e) => {
				e.preventDefault();
				statusEl.hidden = true;
				statusEl.textContent = '';

				const consent = form.querySelector('.consent__checkbox');
				if (consent && !consent.checked) {
					setStatus('err', 'Veuillez accepter la politique de confidentialité pour envoyer le message.');
					return;
				}

				const name = document.getElementById('name')?.value?.trim() ?? '';
				const company = document.getElementById('company')?.value?.trim() ?? '';
				const email = document.getElementById('email')?.value?.trim() ?? '';
				const message = document.getElementById('message')?.value?.trim() ?? '';

				if (!name || !email || !message) {
					setStatus('err', 'Merci de remplir les champs obligatoires (nom, email, message).');
					return;
				}

				submitBtn.disabled = true;
				const prevLabel = submitBtn.textContent;
				submitBtn.textContent = 'Envoi en cours…';

				const payload = {
					name,
					company: company || '—',
					email,
					message,
					submitted_at: new Date().toISOString(),
				};

				try {
					const res = await fetch(contactSubmitUrl, {
						method: 'POST',
						headers: { 'Content-Type': 'application/json' },
						body: JSON.stringify(payload),
					});
					const data = await res.json().catch(() => ({}));
					if (!res.ok) {
						const detail =
							typeof data?.error === 'string' ? ` (${data.error})` : data?.message ? ` (${data.message})` : '';
						throw new Error((res.statusText || 'Erreur') + detail);
					}
					if (data.status === 'success' || data.ok === true || (res.ok && data.attempt != null)) {
						setStatus('ok', 'Merci ! Votre message a bien été envoyé. Je vous réponds dès que possible.');
						form.reset();
					} else {
						throw new Error('Réponse inattendue du serveur');
					}
				} catch (err) {
					console.error('[contact]', err);
					const isNetwork =
						err instanceof TypeError ||
						(err instanceof Error && /failed to fetch|networkerror|load failed/i.test(err.message));
					setStatus(
						'err',
						isNetwork
							? "Connexion impossible (réseau ou serveur). Si vous testez en local sans WAMP, lancez « npm run dev » (proxy intégré) ou déployez le site avec PHP. Sinon écrivez à contact@emmanuelsauvage.fr."
							: "L'envoi a échoué. Réessayez plus tard ou écrivez-moi à contact@emmanuelsauvage.fr.",
					);
				} finally {
					submitBtn.disabled = false;
					submitBtn.textContent = prevLabel;
				}
			});
		})();
	</script>
</Layout>

<style>
	.container {
		width: min(1120px, calc(100% - 48px));
		margin: 0 auto;
	}

	.header {
		position: sticky;
		top: 0;
		z-index: 50;
		background: rgba(247, 248, 251, 0.78);
		backdrop-filter: blur(10px);
		border-bottom: 1px solid var(--color-border);
	}

	.header__inner {
		display: flex;
		align-items: center;
		justify-content: space-between;
		padding: 14px 0;
		gap: 20px;
	}

	.brand {
		display: inline-flex;
		align-items: center;
		gap: 10px;
		text-decoration: none;
		font-weight: 700;
		letter-spacing: -0.02em;
		color: var(--color-primary);
	}

	.brand:hover {
		color: var(--color-primary);
		opacity: 0.88;
	}

	.brand__logoWrap {
		display: inline-flex;
		align-items: center;
		line-height: 0;
	}

	.brand__logo {
		display: block;
		width: 32px;
		height: 32px;
		border-radius: 10px;
		object-fit: cover;
		box-shadow: 0 8px 18px rgba(47, 58, 143, 0.24);
	}

	.nav {
		display: flex;
		align-items: center;
		gap: 14px;
		flex-wrap: wrap;
		justify-content: flex-end;
	}

	.nav__link {
		text-decoration: none;
		color: var(--color-text);
		opacity: 0.9;
		padding: 10px 10px;
		border-radius: 10px;
		transition: background 0.15s ease, opacity 0.15s ease;
	}

	.nav__link:hover {
		opacity: 1;
		background: rgba(47, 58, 143, 0.06);
	}

	.nav__link--current {
		font-weight: 700;
		color: var(--color-primary);
		background: rgba(47, 58, 143, 0.08);
	}

	.nav__cta {
		text-decoration: none;
		color: white;
		background: var(--color-primary);
		padding: 10px 14px;
		border-radius: 12px;
		box-shadow: var(--shadow-sm);
		transition: transform 0.15s ease, box-shadow 0.15s ease;
		white-space: nowrap;
	}

	.nav__cta:hover {
		transform: translateY(-1px);
		box-shadow: var(--shadow-md);
	}

	main {
		display: block;
	}

	.hero {
		position: relative;
		overflow: hidden;
		padding: 56px 0 40px;
		background: white;
		border-bottom: 1px solid var(--color-border);
	}

	.heroFx {
		position: absolute;
		inset: 0;
		pointer-events: none;
		z-index: 0;
	}

	.blob {
		position: absolute;
		border-radius: 999px;
		filter: blur(40px);
		opacity: 0.95;
		mix-blend-mode: multiply;
	}

	.blob--a {
		width: 520px;
		height: 520px;
		top: -220px;
		left: -180px;
		background: radial-gradient(circle at 30% 30%, rgba(79, 110, 247, 0.55), rgba(79, 110, 247, 0) 60%),
			radial-gradient(circle at 70% 60%, rgba(47, 58, 143, 0.35), rgba(47, 58, 143, 0) 65%);
	}

	.blob--b {
		width: 560px;
		height: 560px;
		top: -260px;
		right: -260px;
		background: radial-gradient(circle at 40% 40%, rgba(47, 58, 143, 0.45), rgba(47, 58, 143, 0) 62%),
			radial-gradient(circle at 70% 70%, rgba(79, 110, 247, 0.38), rgba(79, 110, 247, 0) 66%);
	}

	.blob--c {
		width: 520px;
		height: 520px;
		bottom: -300px;
		left: 36%;
		background: radial-gradient(circle at 35% 35%, rgba(79, 110, 247, 0.35), rgba(79, 110, 247, 0) 62%),
			radial-gradient(circle at 70% 40%, rgba(47, 58, 143, 0.2), rgba(47, 58, 143, 0) 70%);
	}

	.heroWave {
		position: absolute;
		inset: auto 0 0 0;
		width: 100%;
		height: 220px;
		opacity: 0.9;
	}

	.hero__grid {
		display: grid;
		grid-template-columns: 1.05fr 0.95fr;
		gap: 42px;
		align-items: center;
		position: relative;
		z-index: 1;
	}

	.backLink {
		display: inline-flex;
		align-items: center;
		gap: 8px;
		margin-bottom: 16px;
		text-decoration: none;
		color: var(--color-primary);
		font-weight: 700;
		letter-spacing: -0.01em;
		font-size: 14px;
	}

	.backLink:hover {
		text-decoration: underline;
		text-decoration-color: rgba(79, 110, 247, 0.45);
	}

	.eyebrow {
		margin: 0 0 10px;
		color: var(--color-muted);
		font-size: 14px;
		letter-spacing: 0.06em;
		text-transform: uppercase;
	}

	h1 {
		margin: 0 0 14px;
		font-size: clamp(30px, 4vw, 48px);
		line-height: 1.08;
		letter-spacing: -0.03em;
	}

	h2 {
		margin: 0 0 12px;
		font-size: clamp(26px, 3vw, 36px);
		letter-spacing: -0.02em;
		line-height: 1.15;
	}

	h3 {
		margin: 0 0 10px;
		font-size: 18px;
		letter-spacing: -0.01em;
	}

	.hero__subtitle {
		margin: 0;
		font-size: 18px;
		color: var(--color-muted);
		opacity: 1;
		max-width: 56ch;
	}

	.trust {
		list-style: none;
		padding: 0;
		margin: 22px 0 0;
		display: grid;
		gap: 8px;
	}

	.trust__item {
		color: var(--color-muted);
		background: rgba(255, 255, 255, 0.8);
		border: 1px solid var(--color-border);
		border-radius: 14px;
		padding: 10px 12px;
		box-shadow: var(--shadow-sm);
	}

	.hero__visual {
		display: flex;
		justify-content: flex-end;
	}

	.heroMedia {
		margin: 0;
		width: min(520px, 100%);
		border-radius: 22px;
		overflow: hidden;
		border: 1px solid var(--color-border);
		box-shadow: var(--shadow-md);
		background: rgba(255, 255, 255, 0.85);
		position: relative;
	}

	.heroMedia::after {
		content: '';
		position: absolute;
		inset: 0;
		background: linear-gradient(180deg, rgba(47, 58, 143, 0) 40%, rgba(47, 58, 143, 0.12) 100%);
		pointer-events: none;
	}

	.heroMedia__img {
		display: block;
		width: 100%;
		height: auto;
		transform: scale(1.02);
	}

	.section {
		padding: 56px 0;
	}

	.section--alt {
		background: rgba(255, 255, 255, 0.7);
		border-top: 1px solid var(--color-border);
		border-bottom: 1px solid var(--color-border);
	}

	.section__head {
		display: grid;
		gap: 10px;
		margin-bottom: 22px;
		max-width: 62ch;
	}

	.section__head p {
		margin: 0;
		color: var(--color-muted);
		opacity: 1;
		font-size: 17px;
	}

	.grid2 {
		display: grid;
		grid-template-columns: 1.1fr 0.9fr;
		gap: 28px;
		align-items: start;
	}

	.form.card {
		padding: 22px;
	}

	.form {
		display: block;
	}

	.card {
		background: rgba(255, 255, 255, 0.92);
		border: 1px solid var(--color-border);
		border-radius: var(--radius);
		padding: 18px;
		box-shadow: var(--shadow-sm);
	}

	.card--accent {
		background: linear-gradient(180deg, rgba(47, 58, 143, 0.06), rgba(255, 255, 255, 0.95));
		border-color: rgba(47, 58, 143, 0.18);
	}

	.card__text {
		margin: 0 0 14px;
		color: var(--color-text);
		opacity: 0.92;
		line-height: 1.55;
	}

	.card__text a {
		color: var(--color-primary);
		font-weight: 600;
		text-decoration: none;
	}

	.card__text a:hover {
		text-decoration: underline;
		text-decoration-color: rgba(79, 110, 247, 0.45);
	}

	.callout {
		background: rgba(255, 255, 255, 0.92);
		border: 1px solid var(--color-border);
		border-radius: var(--radius);
		padding: 18px;
		box-shadow: var(--shadow-sm);
	}

	.checklist {
		margin: 12px 0 0;
		padding-left: 18px;
		color: var(--color-muted);
	}

	.checklist li + li {
		margin-top: 8px;
	}

	.side {
		display: grid;
		gap: 14px;
	}

	.formStatus {
		margin: 0 0 14px;
		padding: 12px 14px;
		border-radius: 12px;
		font-size: 14px;
		font-weight: 600;
	}

	.formStatus--ok {
		background: rgba(47, 58, 143, 0.08);
		border: 1px solid rgba(47, 58, 143, 0.2);
		color: var(--color-primary);
	}

	.formStatus--err {
		background: rgba(220, 38, 38, 0.08);
		border: 1px solid rgba(220, 38, 38, 0.25);
		color: #b91c1c;
	}

	.field {
		display: grid;
		gap: 8px;
		margin-bottom: 14px;
	}

	label {
		font-weight: 700;
		letter-spacing: -0.01em;
	}

	input,
	textarea {
		font: inherit;
		padding: 12px 14px;
		border-radius: 14px;
		border: 1px solid var(--color-border);
		background: rgba(247, 248, 251, 0.85);
		outline: none;
	}

	input:focus,
	textarea:focus {
		border-color: rgba(47, 58, 143, 0.45);
		box-shadow: 0 0 0 4px rgba(47, 58, 143, 0.12);
		background: rgba(255, 255, 255, 1);
	}

	.hint {
		margin: 12px 0 0;
		color: var(--color-muted);
